{
  "surah": 78,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ عَمَّ يَتَسَآءَلُونَ",
      "start_seconds": 0.0,
      "end_seconds": 3.84
    },
    {
      "ayah": 2,
      "text": "عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ",
      "start_seconds": 9.04,
      "end_seconds": 12.76
    },
    {
      "ayah": 3,
      "text": "ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ",
      "start_seconds": 12.76,
      "end_seconds": 16.88
    },
    {
      "ayah": 4,
      "text": "كَلَّا سَيَعْلَمُونَ",
      "start_seconds": 16.88,
      "end_seconds": 19.88
    },
    {
      "ayah": 5,
      "text": "ثُمَّ كَلَّا سَيَعْلَمُونَ",
      "start_seconds": 19.88,
      "end_seconds": 24.12
    },
    {
      "ayah": 6,
      "text": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَـٰدًا",
      "start_seconds": 24.12,
      "end_seconds": 28.12
    },
    {
      "ayah": 7,
      "text": "وَٱلْجِبَالَ أَوْتَادًا",
      "start_seconds": 28.240000000000002,
      "end_seconds": 31.64
    },
    {
      "ayah": 8,
      "text": "وَخَلَقْنَـٰكُمْ أَزْوَٰجًا",
      "start_seconds": 31.64,
      "end_seconds": 35.44
    },
    {
      "ayah": 9,
      "text": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا",
      "start_seconds": 35.44,
      "end_seconds": 39.96
    },
    {
      "ayah": 10,
      "text": "وَجَعَلْنَا ٱلَّيْلَ لِبَاسًا",
      "start_seconds": 39.96,
      "end_seconds": 43.88
    },
    {
      "ayah": 11,
      "text": "وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًا",
      "start_seconds": 43.88,
      "end_seconds": 49.0
    },
    {
      "ayah": 12,
      "text": "وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا",
      "start_seconds": 49.0,
      "end_seconds": 54.72
    },
    {
      "ayah": 13,
      "text": "وَجَعَلْنَا سِرَاجًا وَهَّاجًا",
      "start_seconds": 54.839999999999996,
      "end_seconds": 60.04
    },
    {
      "ayah": 14,
      "text": "وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءً ثَجَّاجًا",
      "start_seconds": 60.04,
      "end_seconds": 68.92
    },
    {
      "ayah": 15,
      "text": "لِّنُخْرِجَ بِهِۦ حَبًّا وَنَبَاتًا",
      "start_seconds": 68.92,
      "end_seconds": 74.56
    },
    {
      "ayah": 16,
      "text": "وَجَنَّـٰتٍ أَلْفَافًا",
      "start_seconds": 74.56,
      "end_seconds": 78.88
    },
    {
      "ayah": 17,
      "text": "إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَـٰتًا",
      "start_seconds": 78.88,
      "end_seconds": 84.6
    },
    {
      "ayah": 18,
      "text": "يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًا",
      "start_seconds": 84.6,
      "end_seconds": 91.36
    },
    {
      "ayah": 19,
      "text": "وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًا",
      "start_seconds": 91.36,
      "end_seconds": 97.92
    },
    {
      "ayah": 20,
      "text": "وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا",
      "start_seconds": 97.92,
      "end_seconds": 103.84
    },
    {
      "ayah": 21,
      "text": "إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا",
      "start_seconds": 103.84,
      "end_seconds": 110.0
    },
    {
      "ayah": 22,
      "text": "لِّلطَّـٰغِينَ مَـَٔابًا",
      "start_seconds": 110.0,
      "end_seconds": 114.03999999999999
    },
    {
      "ayah": 23,
      "text": "لَّـٰبِثِينَ فِيهَآ أَحْقَابًا",
      "start_seconds": 114.04,
      "end_seconds": 119.44000000000001
    },
    {
      "ayah": 24,
      "text": "لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا",
      "start_seconds": 119.44000000000001,
      "end_seconds": 126.56
    },
    {
      "ayah": 25,
      "text": "إِلَّا حَمِيمًا وَغَسَّاقًا",
      "start_seconds": 126.56,
      "end_seconds": 131.52
    },
    {
      "ayah": 26,
      "text": "جَزَآءً وِفَاقًا",
      "start_seconds": 131.52,
      "end_seconds": 136.76
    },
    {
      "ayah": 27,
      "text": "إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًا",
      "start_seconds": 136.76,
      "end_seconds": 142.88
    },
    {
      "ayah": 28,
      "text": "وَكَذَّبُوا۟ بِـَٔايَـٰتِنَا كِذَّابًا",
      "start_seconds": 142.92,
      "end_seconds": 148.32
    },
    {
      "ayah": 29,
      "text": "وَكُلَّ شَىْءٍ أَحْصَيْنَـٰهُ كِتَـٰبًا",
      "start_seconds": 148.32,
      "end_seconds": 153.79999999999998
    },
    {
      "ayah": 30,
      "text": "فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا",
      "start_seconds": 153.79999999999998,
      "end_seconds": 160.68
    },
    {
      "ayah": 31,
      "text": "إِنَّ لِلْمُتَّقِينَ مَفَازًا",
      "start_seconds": 160.68,
      "end_seconds": 165.51999999999998
    },
    {
      "ayah": 32,
      "text": "حَدَآئِقَ وَأَعْنَـٰبًا",
      "start_seconds": 165.51999999999998,
      "end_seconds": 170.4
    },
    {
      "ayah": 33,
      "text": "وَكَوَاعِبَ أَتْرَابًا",
      "start_seconds": 170.44,
      "end_seconds": 174.0
    },
    {
      "ayah": 34,
      "text": "وَكَأْسًا دِهَاقًا",
      "start_seconds": 174.0,
      "end_seconds": 177.92000000000002
    },
    {
      "ayah": 35,
      "text": "لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّٰبًا",
      "start_seconds": 177.92000000000002,
      "end_seconds": 185.48000000000002
    },
    {
      "ayah": 36,
      "text": "جَزَآءً مِّن رَّبِّكَ عَطَآءً حِسَابًا",
      "start_seconds": 185.48000000000002,
      "end_seconds": 194.88
    },
    {
      "ayah": 37,
      "text": "رَّبِّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَـٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا",
      "start_seconds": 194.88,
      "end_seconds": 206.48
    },
    {
      "ayah": 38,
      "text": "يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَـٰٓئِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَـٰنُ وَقَالَ صَوَابًا",
      "start_seconds": 206.48,
      "end_seconds": 226.76
    },
    {
      "ayah": 39,
      "text": "ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا",
      "start_seconds": 226.76,
      "end_seconds": 235.0
    }
  ]
}