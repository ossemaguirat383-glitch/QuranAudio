{
  "surah": 92,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ",
      "start_seconds": 0,
      "end_seconds": 7.92
    },
    {
      "ayah": 2,
      "text": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ",
      "start_seconds": 7.92,
      "end_seconds": 13.040000000000001
    },
    {
      "ayah": 3,
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "start_seconds": 13.040000000000001,
      "end_seconds": 18.240000000000002
    },
    {
      "ayah": 4,
      "text": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
      "start_seconds": 18.240000000000002,
      "end_seconds": 22.96
    },
    {
      "ayah": 5,
      "text": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ",
      "start_seconds": 22.96,
      "end_seconds": 28.240000000000002
    },
    {
      "ayah": 6,
      "text": "وَصَدَّقَ بِٱلْحُسْنَىٰ",
      "start_seconds": 28.24,
      "end_seconds": 31.68
    },
    {
      "ayah": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ",
      "start_seconds": 31.68,
      "end_seconds": 36.0
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ",
      "start_seconds": 36.0,
      "end_seconds": 41.839999999999996
    },
    {
      "ayah": 9,
      "text": "وَكَذَّبَ بِٱلْحُسْنَىٰ",
      "start_seconds": 41.839999999999996,
      "end_seconds": 45.28
    },
    {
      "ayah": 10,
      "text": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ",
      "start_seconds": 45.28,
      "end_seconds": 49.519999999999996
    },
    {
      "ayah": 11,
      "text": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
      "start_seconds": 49.519999999999996,
      "end_seconds": 57.04
    },
    {
      "ayah": 12,
      "text": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
      "start_seconds": 57.12,
      "end_seconds": 61.36
    },
    {
      "ayah": 13,
      "text": "وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ",
      "start_seconds": 61.36,
      "end_seconds": 67.68
    },
    {
      "ayah": 14,
      "text": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ",
      "start_seconds": 67.68,
      "end_seconds": 73.6
    },
    {
      "ayah": 15,
      "text": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى",
      "start_seconds": 73.6,
      "end_seconds": 79.36
    },
    {
      "ayah": 16,
      "text": "ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ",
      "start_seconds": 79.36,
      "end_seconds": 83.84
    },
    {
      "ayah": 17,
      "text": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى",
      "start_seconds": 84.0,
      "end_seconds": 88.48
    },
    {
      "ayah": 18,
      "text": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ",
      "start_seconds": 88.48,
      "end_seconds": 94.16
    },
    {
      "ayah": 19,
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ",
      "start_seconds": 94.16,
      "end_seconds": 102.96000000000001
    },
    {
      "ayah": 20,
      "text": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ",
      "start_seconds": 102.96000000000001,
      "end_seconds": 110.08000000000001
    },
    {
      "ayah": 21,
      "text": "وَلَسَوْفَ يَرْضَىٰ",
      "start_seconds": 110.08000000000001,
      "end_seconds": 113.12
    }
  ]
}