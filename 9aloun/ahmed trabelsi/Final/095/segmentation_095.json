{
  "surah": 95,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِّسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلتِّينِ وَٱلزَّيْتُونِ",
      "start_seconds": 0,
      "end_seconds": 8.68
    },
    {
      "ayah": 2,
      "text": "وَطُورِ سِينِينَ",
      "start_seconds": 8.68,
      "end_seconds": 11.68
    },
    {
      "ayah": 3,
      "text": "وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ",
      "start_seconds": 11.68,
      "end_seconds": 15.280000000000001
    },
    {
      "ayah": 4,
      "text": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ",
      "start_seconds": 15.280000000000001,
      "end_seconds": 23.44
    },
    {
      "ayah": 5,
      "text": "ثُمَّ رَدَدْنَـٰهُ أَسْفَلَ سَـٰفِلِينَ",
      "start_seconds": 23.44,
      "end_seconds": 29.44
    },
    {
      "ayah": 6,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ",
      "start_seconds": 29.44,
      "end_seconds": 40.08
    },
    {
      "ayah": 7,
      "text": "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ",
      "start_seconds": 40.08,
      "end_seconds": 44.96
    },
    {
      "ayah": 8,
      "text": "أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَـٰكِمِينَ",
      "start_seconds": 44.96,
      "end_seconds": 50.32
    }
  ]
}