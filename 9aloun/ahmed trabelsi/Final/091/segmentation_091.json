{
  "surah": 91,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا",
      "start_seconds": 0,
      "end_seconds": 8.2
    },
    {
      "ayah": 2,
      "text": "وَٱلْقَمَرِ إِذَا تَلَىٰهَا",
      "start_seconds": 8.2,
      "end_seconds": 12.32
    },
    {
      "ayah": 3,
      "text": "وَٱلنَّهَارِ إِذَا جَلَّىٰهَا",
      "start_seconds": 12.32,
      "end_seconds": 17.68
    },
    {
      "ayah": 4,
      "text": "وَٱلَّيْلِ إِذَا يَغْشَىٰهَا",
      "start_seconds": 17.68,
      "end_seconds": 22.080000000000002
    },
    {
      "ayah": 5,
      "text": "وَٱلسَّمَآءِ وَمَا بَنَىٰهَا",
      "start_seconds": 22.08,
      "end_seconds": 28.0
    },
    {
      "ayah": 6,
      "text": "وَٱلْأَرْضِ وَمَا طَحَىٰهَا",
      "start_seconds": 28.0,
      "end_seconds": 32.12
    },
    {
      "ayah": 7,
      "text": "وَنَفْسٍ وَمَا سَوَّىٰهَا",
      "start_seconds": 32.12,
      "end_seconds": 37.24
    },
    {
      "ayah": 8,
      "text": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا",
      "start_seconds": 37.24,
      "end_seconds": 43.28
    },
    {
      "ayah": 9,
      "text": "قَدْ أَفْلَحَ مَن زَكَّىٰهَا",
      "start_seconds": 43.28,
      "end_seconds": 48.36
    },
    {
      "ayah": 10,
      "text": "وَقَدْ خَابَ مَن دَسَّىٰهَا",
      "start_seconds": 48.36,
      "end_seconds": 53.36
    },
    {
      "ayah": 11,
      "text": "كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ",
      "start_seconds": 53.4,
      "end_seconds": 58.2
    },
    {
      "ayah": 12,
      "text": "إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا",
      "start_seconds": 58.2,
      "end_seconds": 63.04
    },
    {
      "ayah": 13,
      "text": "فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَـٰهَا",
      "start_seconds": 63.04,
      "end_seconds": 85.2
    },
    {
      "ayah": 15,
      "text": "وَلَا يَخَافُ عُقْبَـٰهَا",
      "start_seconds": 85.2,
      "end_seconds": 89.2
    }
  ]
}