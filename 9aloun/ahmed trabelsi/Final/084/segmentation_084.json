{
  "surah": 84,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ",
      "start_seconds": 0,
      "end_seconds": 9.72
    },
    {
      "ayah": 2,
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
      "start_seconds": 9.72,
      "end_seconds": 14.08
    },
    {
      "ayah": 3,
      "text": "وَإِذَا ٱلْأَرْضُ مُدَّتْ",
      "start_seconds": 14.08,
      "end_seconds": 17.240000000000002
    },
    {
      "ayah": 4,
      "text": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ",
      "start_seconds": 17.240000000000002,
      "end_seconds": 22.12
    },
    {
      "ayah": 5,
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
      "start_seconds": 22.12,
      "end_seconds": 26.4
    },
    {
      "ayah": 6,
      "text": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًا فَمُلَـٰقِيهِ",
      "start_seconds": 26.4,
      "end_seconds": 39.68
    },
    {
      "ayah": 7,
      "text": "فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ",
      "start_seconds": 39.68,
      "end_seconds": 46.480000000000004
    },
    {
      "ayah": 8,
      "text": "فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا",
      "start_seconds": 46.480000000000004,
      "end_seconds": 52.480000000000004
    },
    {
      "ayah": 9,
      "text": "وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا",
      "start_seconds": 52.48,
      "end_seconds": 60.08
    },
    {
      "ayah": 10,
      "text": "وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ وَرَآءَ ظَهْرِهِۦ",
      "start_seconds": 60.08,
      "end_seconds": 68.52
    },
    {
      "ayah": 11,
      "text": "فَسَوْفَ يَدْعُوا۟ ثُبُورًا",
      "start_seconds": 68.52,
      "end_seconds": 72.32
    },
    {
      "ayah": 12,
      "text": "وَيَصْلَىٰ سَعِيرًا",
      "start_seconds": 72.32,
      "end_seconds": 75.8
    },
    {
      "ayah": 13,
      "text": "إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا",
      "start_seconds": 75.84,
      "end_seconds": 83.67999999999999
    },
    {
      "ayah": 14,
      "text": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ",
      "start_seconds": 83.67999999999999,
      "end_seconds": 90.16
    },
    {
      "ayah": 15,
      "text": "بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًا",
      "start_seconds": 90.16,
      "end_seconds": 97.6
    },
    {
      "ayah": 16,
      "text": "فَلَآ أُقْسِمُ بِٱلشَّفَقِ",
      "start_seconds": 97.6,
      "end_seconds": 101.88
    },
    {
      "ayah": 17,
      "text": "وَٱلَّيْلِ وَمَا وَسَقَ",
      "start_seconds": 101.88,
      "end_seconds": 105.16
    },
    {
      "ayah": 18,
      "text": "وَٱلْقَمَرِ إِذَا ٱتَّسَقَ",
      "start_seconds": 105.2,
      "end_seconds": 108.39999999999999
    },
    {
      "ayah": 19,
      "text": "لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ",
      "start_seconds": 108.39999999999999,
      "end_seconds": 114.39999999999999
    },
    {
      "ayah": 20,
      "text": "فَمَا لَهُمْ لَا يُؤْمِنُونَ",
      "start_seconds": 114.39999999999999,
      "end_seconds": 118.72
    },
    {
      "ayah": 21,
      "text": "وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩",
      "start_seconds": 118.72,
      "end_seconds": 125.67999999999999
    },
    {
      "ayah": 22,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ",
      "start_seconds": 125.67999999999999,
      "end_seconds": 130.64
    },
    {
      "ayah": 23,
      "text": "وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ",
      "start_seconds": 130.67999999999998,
      "end_seconds": 135.35999999999999
    },
    {
      "ayah": 24,
      "text": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ",
      "start_seconds": 135.35999999999999,
      "end_seconds": 140.6
    }
  ]
}