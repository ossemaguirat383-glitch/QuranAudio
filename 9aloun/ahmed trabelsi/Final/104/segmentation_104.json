{
  "surah": 104,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
      "start_seconds": 0,
      "end_seconds": 14.92
    },
    {
      "ayah": 3,
      "text": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
      "start_seconds": 14.92,
      "end_seconds": 20.92
    },
    {
      "ayah": 4,
      "text": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
      "start_seconds": 20.92,
      "end_seconds": 26.92
    },
    {
      "ayah": 5,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
      "start_seconds": 26.92,
      "end_seconds": 31.96
    },
    {
      "ayah": 6,
      "text": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
      "start_seconds": 31.96,
      "end_seconds": 35.64
    },
    {
      "ayah": 7,
      "text": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
      "start_seconds": 35.64,
      "end_seconds": 40.52
    },
    {
      "ayah": 8,
      "text": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ",
      "start_seconds": 40.52,
      "end_seconds": 45.72
    },
    {
      "ayah": 9,
      "text": "فِى عَمَدٍ مُّمَدَّدَةٍۭ",
      "start_seconds": 45.72,
      "end_seconds": 50.120000000000005
    }
  ]
}