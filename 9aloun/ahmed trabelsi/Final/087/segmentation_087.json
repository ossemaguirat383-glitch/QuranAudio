{
  "surah": 87,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
      "start_seconds": 0,
      "end_seconds": 9.24
    },
    {
      "ayah": 2,
      "text": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
      "start_seconds": 9.24,
      "end_seconds": 13.16
    },
    {
      "ayah": 3,
      "text": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
      "start_seconds": 13.16,
      "end_seconds": 16.96
    },
    {
      "ayah": 4,
      "text": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
      "start_seconds": 16.96,
      "end_seconds": 22.12
    },
    {
      "ayah": 5,
      "text": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
      "start_seconds": 22.12,
      "end_seconds": 27.6
    },
    {
      "ayah": 6,
      "text": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "start_seconds": 27.76,
      "end_seconds": 32.24
    },
    {
      "ayah": 7,
      "text": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "start_seconds": 37.04,
      "end_seconds": 42.8
    },
    {
      "ayah": 8,
      "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "start_seconds": 42.800000000000004,
      "end_seconds": 46.64
    },
    {
      "ayah": 9,
      "text": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
      "start_seconds": 46.64,
      "end_seconds": 52.08
    },
    {
      "ayah": 10,
      "text": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "start_seconds": 52.08,
      "end_seconds": 56.400000000000006
    },
    {
      "ayah": 11,
      "text": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
      "start_seconds": 56.4,
      "end_seconds": 61.04
    },
    {
      "ayah": 12,
      "text": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "start_seconds": 61.04,
      "end_seconds": 66.4
    },
    {
      "ayah": 13,
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "start_seconds": 66.4,
      "end_seconds": 72.8
    },
    {
      "ayah": 14,
      "text": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "start_seconds": 72.8,
      "end_seconds": 77.36
    },
    {
      "ayah": 15,
      "text": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
      "start_seconds": 77.36,
      "end_seconds": 82.0
    },
    {
      "ayah": 16,
      "text": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "start_seconds": 82.08,
      "end_seconds": 87.2
    },
    {
      "ayah": 17,
      "text": "وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ",
      "start_seconds": 87.2,
      "end_seconds": 92.24
    },
    {
      "ayah": 18,
      "text": "إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
      "start_seconds": 92.24,
      "end_seconds": 98.0
    },
    {
      "ayah": 19,
      "text": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
      "start_seconds": 98.0,
      "end_seconds": 102.8
    }
  ]
}