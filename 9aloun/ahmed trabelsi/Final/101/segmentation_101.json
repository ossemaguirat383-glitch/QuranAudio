{
  "surah": 101,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ",
      "start_seconds": 0.0,
      "end_seconds": 4.76
    },
    {
      "ayah": 2,
      "text": "مَا ٱلْقَارِعَةُ",
      "start_seconds": 7.0,
      "end_seconds": 9.44
    },
    {
      "ayah": 3,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ",
      "start_seconds": 9.44,
      "end_seconds": 15.24
    },
    {
      "ayah": 4,
      "text": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
      "start_seconds": 15.24,
      "end_seconds": 22.12
    },
    {
      "ayah": 5,
      "text": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
      "start_seconds": 22.12,
      "end_seconds": 28.68
    },
    {
      "ayah": 6,
      "text": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
      "start_seconds": 28.8,
      "end_seconds": 34.84
    },
    {
      "ayah": 7,
      "text": "فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ",
      "start_seconds": 34.84,
      "end_seconds": 39.16
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
      "start_seconds": 39.16,
      "end_seconds": 44.8
    },
    {
      "ayah": 9,
      "text": "فَأُمُّهُۥ هَاوِيَةٌ",
      "start_seconds": 44.8,
      "end_seconds": 48.72
    },
    {
      "ayah": 10,
      "text": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
      "start_seconds": 48.72,
      "end_seconds": 53.2
    },
    {
      "ayah": 11,
      "text": "نَارٌ حَامِيَةٌۢ",
      "start_seconds": 53.2,
      "end_seconds": 55.879999999999995
    }
  ]
}