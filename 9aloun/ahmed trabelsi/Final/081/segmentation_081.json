{
  "surah": 81,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ",
      "start_seconds": 0,
      "end_seconds": 7.2
    },
    {
      "ayah": 2,
      "text": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
      "start_seconds": 7.2,
      "end_seconds": 11.84
    },
    {
      "ayah": 3,
      "text": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
      "start_seconds": 11.84,
      "end_seconds": 15.280000000000001
    },
    {
      "ayah": 4,
      "text": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
      "start_seconds": 15.280000000000001,
      "end_seconds": 18.72
    },
    {
      "ayah": 5,
      "text": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
      "start_seconds": 18.72,
      "end_seconds": 21.96
    },
    {
      "ayah": 6,
      "text": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
      "start_seconds": 21.96,
      "end_seconds": 25.48
    },
    {
      "ayah": 7,
      "text": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
      "start_seconds": 25.48,
      "end_seconds": 29.64
    },
    {
      "ayah": 8,
      "text": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
      "start_seconds": 29.64,
      "end_seconds": 33.36
    },
    {
      "ayah": 9,
      "text": "بِأَىِّ ذَنۢبٍ قُتِلَتْ",
      "start_seconds": 33.36,
      "end_seconds": 37.88
    },
    {
      "ayah": 10,
      "text": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
      "start_seconds": 37.88,
      "end_seconds": 40.88
    },
    {
      "ayah": 11,
      "text": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
      "start_seconds": 40.88,
      "end_seconds": 44.96
    },
    {
      "ayah": 12,
      "text": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
      "start_seconds": 44.96,
      "end_seconds": 48.6
    },
    {
      "ayah": 13,
      "text": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
      "start_seconds": 48.6,
      "end_seconds": 52.84
    },
    {
      "ayah": 14,
      "text": "عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ",
      "start_seconds": 52.84,
      "end_seconds": 58.519999999999996
    },
    {
      "ayah": 15,
      "text": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
      "start_seconds": 58.52,
      "end_seconds": 63.68000000000001
    },
    {
      "ayah": 16,
      "text": "ٱلْجَوَارِ ٱلْكُنَّسِ",
      "start_seconds": 63.68000000000001,
      "end_seconds": 67.72
    },
    {
      "ayah": 17,
      "text": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
      "start_seconds": 67.72,
      "end_seconds": 71.16
    },
    {
      "ayah": 18,
      "text": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
      "start_seconds": 71.16,
      "end_seconds": 74.76
    },
    {
      "ayah": 19,
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ",
      "start_seconds": 74.76,
      "end_seconds": 80.52
    },
    {
      "ayah": 20,
      "text": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ",
      "start_seconds": 80.52000000000001,
      "end_seconds": 86.60000000000001
    },
    {
      "ayah": 21,
      "text": "مُّطَاعٍ ثَمَّ أَمِينٍ",
      "start_seconds": 86.64,
      "end_seconds": 91.28
    },
    {
      "ayah": 22,
      "text": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
      "start_seconds": 91.28,
      "end_seconds": 96.28
    },
    {
      "ayah": 23,
      "text": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
      "start_seconds": 96.28,
      "end_seconds": 101.28
    },
    {
      "ayah": 24,
      "text": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ",
      "start_seconds": 101.28,
      "end_seconds": 105.67999999999999
    },
    {
      "ayah": 25,
      "text": "وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ",
      "start_seconds": 105.67999999999999,
      "end_seconds": 111.03999999999999
    },
    {
      "ayah": 26,
      "text": "فَأَيْنَ تَذْهَبُونَ",
      "start_seconds": 111.03999999999999,
      "end_seconds": 113.96
    },
    {
      "ayah": 27,
      "text": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ",
      "start_seconds": 113.96,
      "end_seconds": 119.44
    },
    {
      "ayah": 28,
      "text": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
      "start_seconds": 119.44,
      "end_seconds": 127.63999999999999
    },
    {
      "ayah": 29,
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ",
      "start_seconds": 127.63999999999999,
      "end_seconds": 140.4
    }
  ]
}