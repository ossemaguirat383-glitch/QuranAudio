{
  "surah": 96,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
      "start_seconds": 0,
      "end_seconds": 9.88
    },
    {
      "ayah": 2,
      "text": "خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ",
      "start_seconds": 9.88,
      "end_seconds": 14.24
    },
    {
      "ayah": 3,
      "text": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
      "start_seconds": 14.24,
      "end_seconds": 18.16
    },
    {
      "ayah": 4,
      "text": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
      "start_seconds": 18.16,
      "end_seconds": 22.04
    },
    {
      "ayah": 5,
      "text": "عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ",
      "start_seconds": 22.04,
      "end_seconds": 27.52
    },
    {
      "ayah": 6,
      "text": "كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ",
      "start_seconds": 27.52,
      "end_seconds": 34.72
    },
    {
      "ayah": 7,
      "text": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
      "start_seconds": 34.72,
      "end_seconds": 38.0
    },
    {
      "ayah": 8,
      "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
      "start_seconds": 38.0,
      "end_seconds": 42.88
    },
    {
      "ayah": 9,
      "text": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
      "start_seconds": 42.88,
      "end_seconds": 46.68
    },
    {
      "ayah": 10,
      "text": "عَبْدًا إِذَا صَلَّىٰٓ",
      "start_seconds": 46.68,
      "end_seconds": 50.16
    },
    {
      "ayah": 11,
      "text": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
      "start_seconds": 50.16,
      "end_seconds": 55.08
    },
    {
      "ayah": 12,
      "text": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
      "start_seconds": 55.12,
      "end_seconds": 58.48
    },
    {
      "ayah": 13,
      "text": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "start_seconds": 58.48,
      "end_seconds": 63.72
    },
    {
      "ayah": 14,
      "text": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "start_seconds": 63.72,
      "end_seconds": 69.84
    },
    {
      "ayah": 15,
      "text": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
      "start_seconds": 69.84,
      "end_seconds": 78.36
    },
    {
      "ayah": 16,
      "text": "نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ",
      "start_seconds": 78.36,
      "end_seconds": 83.68
    },
    {
      "ayah": 17,
      "text": "فَلْيَدْعُ نَادِيَهُۥ",
      "start_seconds": 83.72000000000001,
      "end_seconds": 86.60000000000001
    },
    {
      "ayah": 18,
      "text": "سَنَدْعُ ٱلزَّبَانِيَةَ",
      "start_seconds": 86.6,
      "end_seconds": 89.88
    },
    {
      "ayah": 19,
      "text": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
      "start_seconds": 89.88000000000001,
      "end_seconds": 95.32000000000001
    }
  ]
}