{
  "surah": 89,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلْفَجْرِ",
      "start_seconds": 0.0,
      "end_seconds": 4.76
    },
    {
      "ayah": 2,
      "text": "وَلَيَالٍ عَشْرٍ",
      "start_seconds": 6.36,
      "end_seconds": 9.0
    },
    {
      "ayah": 3,
      "text": "وَٱلشَّفْعِ وَٱلْوَتْرِ",
      "start_seconds": 9.0,
      "end_seconds": 11.8
    },
    {
      "ayah": 4,
      "text": "وَٱلَّيْلِ إِذَا يَسْرِ",
      "start_seconds": 11.8,
      "end_seconds": 14.8
    },
    {
      "ayah": 5,
      "text": "هَلْ فِى ذَٰلِكَ قَسَمٌ لِّذِى حِجْرٍ",
      "start_seconds": 14.8,
      "end_seconds": 19.84
    },
    {
      "ayah": 6,
      "text": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ",
      "start_seconds": 19.84,
      "end_seconds": 25.12
    },
    {
      "ayah": 7,
      "text": "إِرَمَ ذَاتِ ٱلْعِمَادِ",
      "start_seconds": 25.12,
      "end_seconds": 28.400000000000002
    },
    {
      "ayah": 8,
      "text": "ٱلَّتِى لَمْ يُخْلَقْ مِثْلُهَا فِى ٱلْبِلَـٰدِ",
      "start_seconds": 28.4,
      "end_seconds": 34.4
    },
    {
      "ayah": 9,
      "text": "وَثَمُودَ ٱلَّذِينَ جَابُوا۟ ٱلصَّخْرَ بِٱلْوَادِ",
      "start_seconds": 34.4,
      "end_seconds": 40.4
    },
    {
      "ayah": 10,
      "text": "وَفِرْعَوْنَ ذِى ٱلْأَوْتَادِ",
      "start_seconds": 40.4,
      "end_seconds": 44.28
    },
    {
      "ayah": 11,
      "text": "ٱلَّذِينَ طَغَوْا۟ فِى ٱلْبِلَـٰدِ",
      "start_seconds": 44.28,
      "end_seconds": 48.56
    },
    {
      "ayah": 12,
      "text": "فَأَكْثَرُوا۟ فِيهَا ٱلْفَسَادَ",
      "start_seconds": 48.56,
      "end_seconds": 52.76
    },
    {
      "ayah": 13,
      "text": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ",
      "start_seconds": 52.879999999999995,
      "end_seconds": 58.599999999999994
    },
    {
      "ayah": 14,
      "text": "إِنَّ رَبَّكَ لَبِٱلْمِرْصَادِ",
      "start_seconds": 58.599999999999994,
      "end_seconds": 63.8
    },
    {
      "ayah": 15,
      "text": "فَأَمَّا ٱلْإِنسَـٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ",
      "start_seconds": 63.8,
      "end_seconds": 94.72
    },
    {
      "ayah": 17,
      "text": "كَلَّا ۖ بَل لَّا تُكْرِمُونَ ٱلْيَتِيمَ",
      "start_seconds": 94.72,
      "end_seconds": 100.28
    },
    {
      "ayah": 18,
      "text": "وَلَا تَحَـٰٓضُّونَ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "start_seconds": 100.28,
      "end_seconds": 109.52
    },
    {
      "ayah": 19,
      "text": "وَتَأْكُلُونَ ٱلتُّرَاثَ أَكْلًا لَّمًّا",
      "start_seconds": 109.52,
      "end_seconds": 116.28
    },
    {
      "ayah": 20,
      "text": "وَتُحِبُّونَ ٱلْمَالَ حُبًّا جَمًّا",
      "start_seconds": 116.28,
      "end_seconds": 123.36
    },
    {
      "ayah": 21,
      "text": "كَلَّآ إِذَا دُكَّتِ ٱلْأَرْضُ دَكًّا دَكًّا",
      "start_seconds": 123.36,
      "end_seconds": 131.35999999999999
    },
    {
      "ayah": 22,
      "text": "وَجَآءَ رَبُّكَ وَٱلْمَلَكُ صَفًّا صَفًّا",
      "start_seconds": 131.36,
      "end_seconds": 139.48
    },
    {
      "ayah": 23,
      "text": "وَجِا۟ىٓءَ يَوْمَئِذٍۭ بِجَهَنَّمَ ۚ يَوْمَئِذٍ يَتَذَكَّرُ ٱلْإِنسَـٰنُ وَأَنَّىٰ لَهُ ٱلذِّكْرَىٰ",
      "start_seconds": 139.48,
      "end_seconds": 163.56
    },
    {
      "ayah": 25,
      "text": "فَيَوْمَئِذٍ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٌ",
      "start_seconds": 163.56,
      "end_seconds": 171.0
    },
    {
      "ayah": 26,
      "text": "وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٌ",
      "start_seconds": 171.0,
      "end_seconds": 176.8
    },
    {
      "ayah": 27,
      "text": "يَـٰٓأَيَّتُهَا ٱلنَّفْسُ ٱلْمُطْمَئِنَّةُ",
      "start_seconds": 176.8,
      "end_seconds": 184.88
    },
    {
      "ayah": 28,
      "text": "ٱرْجِعِىٓ إِلَىٰ رَبِّكِ رَاضِيَةً مَّرْضِيَّةً",
      "start_seconds": 184.88,
      "end_seconds": 193.6
    },
    {
      "ayah": 29,
      "text": "فَٱدْخُلِى فِى عِبَـٰدِى",
      "start_seconds": 193.6,
      "end_seconds": 197.32
    },
    {
      "ayah": 30,
      "text": "وَٱدْخُلِى جَنَّتِى",
      "start_seconds": 197.32,
      "end_seconds": 201.32
    }
  ]
}