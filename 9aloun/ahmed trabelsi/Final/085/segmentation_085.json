{
  "surah": 85,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ",
      "start_seconds": 0,
      "end_seconds": 9.14
    },
    {
      "ayah": 2,
      "text": "وَٱلْيَوْمِ ٱلْمَوْعُودِ",
      "start_seconds": 9.14,
      "end_seconds": 12.2
    },
    {
      "ayah": 3,
      "text": "وَشَاهِدٍ وَمَشْهُودٍ",
      "start_seconds": 12.2,
      "end_seconds": 15.9
    },
    {
      "ayah": 4,
      "text": "قُتِلَ أَصْحَـٰبُ ٱلْأُخْدُودِ",
      "start_seconds": 15.9,
      "end_seconds": 19.740000000000002
    },
    {
      "ayah": 5,
      "text": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ",
      "start_seconds": 19.740000000000002,
      "end_seconds": 23.92
    },
    {
      "ayah": 6,
      "text": "إِذْ هُمْ عَلَيْهَا قُعُودٌ",
      "start_seconds": 23.92,
      "end_seconds": 27.44
    },
    {
      "ayah": 7,
      "text": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ",
      "start_seconds": 27.44,
      "end_seconds": 34.260000000000005
    },
    {
      "ayah": 8,
      "text": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ",
      "start_seconds": 34.260000000000005,
      "end_seconds": 45.44
    },
    {
      "ayah": 9,
      "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍ شَهِيدٌ",
      "start_seconds": 45.44,
      "end_seconds": 56.88
    },
    {
      "ayah": 10,
      "text": "إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَـٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ",
      "start_seconds": 56.88,
      "end_seconds": 70.64
    },
    {
      "ayah": 11,
      "text": "إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ جَنَّـٰتٌ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ",
      "start_seconds": 74.6,
      "end_seconds": 89.6
    },
    {
      "ayah": 12,
      "text": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ",
      "start_seconds": 93.52,
      "end_seconds": 98.32
    },
    {
      "ayah": 13,
      "text": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ",
      "start_seconds": 98.32,
      "end_seconds": 103.39999999999999
    },
    {
      "ayah": 14,
      "text": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ",
      "start_seconds": 103.4,
      "end_seconds": 106.92
    },
    {
      "ayah": 15,
      "text": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ",
      "start_seconds": 106.92,
      "end_seconds": 110.08000000000001
    },
    {
      "ayah": 16,
      "text": "فَعَّالٌ لِّمَا يُرِيدُ",
      "start_seconds": 110.08000000000001,
      "end_seconds": 113.76
    },
    {
      "ayah": 17,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ",
      "start_seconds": 113.76,
      "end_seconds": 118.2
    },
    {
      "ayah": 18,
      "text": "فِرْعَوْنَ وَثَمُودَ",
      "start_seconds": 118.2,
      "end_seconds": 121.32000000000001
    },
    {
      "ayah": 19,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ",
      "start_seconds": 121.32000000000001,
      "end_seconds": 126.28
    },
    {
      "ayah": 20,
      "text": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ",
      "start_seconds": 126.36,
      "end_seconds": 133.8
    },
    {
      "ayah": 21,
      "text": "بَلْ هُوَ قُرْءَانٌ مَّجِيدٌ",
      "start_seconds": 133.8,
      "end_seconds": 138.28
    },
    {
      "ayah": 22,
      "text": "فِى لَوْحٍ مَّحْفُوظٍۭ",
      "start_seconds": 138.28,
      "end_seconds": 142.28
    }
  ]
}