{
  "surah": 88,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ",
      "start_seconds": 0,
      "end_seconds": 9.68
    },
    {
      "ayah": 2,
      "text": "وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ",
      "start_seconds": 9.68,
      "end_seconds": 14.92
    },
    {
      "ayah": 3,
      "text": "عَامِلَةٌ نَّاصِبَةٌ",
      "start_seconds": 14.92,
      "end_seconds": 18.96
    },
    {
      "ayah": 4,
      "text": "تَصْلَىٰ نَارًا حَامِيَةً",
      "start_seconds": 18.96,
      "end_seconds": 22.92
    },
    {
      "ayah": 5,
      "text": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ",
      "start_seconds": 22.92,
      "end_seconds": 27.36
    },
    {
      "ayah": 6,
      "text": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
      "start_seconds": 27.36,
      "end_seconds": 34.08
    },
    {
      "ayah": 7,
      "text": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ",
      "start_seconds": 34.08,
      "end_seconds": 40.12
    },
    {
      "ayah": 8,
      "text": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
      "start_seconds": 40.12,
      "end_seconds": 45.6
    },
    {
      "ayah": 9,
      "text": "لِّسَعْيِهَا رَاضِيَةٌ",
      "start_seconds": 45.6,
      "end_seconds": 48.879999999999995
    },
    {
      "ayah": 10,
      "text": "فِى جَنَّةٍ عَالِيَةٍ",
      "start_seconds": 48.879999999999995,
      "end_seconds": 53.480000000000004
    },
    {
      "ayah": 11,
      "text": "لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً",
      "start_seconds": 53.599999999999994,
      "end_seconds": 58.12
    },
    {
      "ayah": 12,
      "text": "فِيهَا عَيْنٌ جَارِيَةٌ",
      "start_seconds": 58.12,
      "end_seconds": 62.72
    },
    {
      "ayah": 13,
      "text": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
      "start_seconds": 62.72,
      "end_seconds": 67.52
    },
    {
      "ayah": 14,
      "text": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
      "start_seconds": 67.52,
      "end_seconds": 72.28
    },
    {
      "ayah": 15,
      "text": "وَنَمَارِقُ مَصْفُوفَةٌ",
      "start_seconds": 72.28,
      "end_seconds": 75.96
    },
    {
      "ayah": 16,
      "text": "وَزَرَابِىُّ مَبْثُوثَةٌ",
      "start_seconds": 75.96,
      "end_seconds": 79.96
    },
    {
      "ayah": 17,
      "text": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
      "start_seconds": 79.96,
      "end_seconds": 86.88
    },
    {
      "ayah": 18,
      "text": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
      "start_seconds": 86.88,
      "end_seconds": 92.52
    },
    {
      "ayah": 19,
      "text": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
      "start_seconds": 92.52,
      "end_seconds": 96.96
    },
    {
      "ayah": 20,
      "text": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
      "start_seconds": 96.96,
      "end_seconds": 101.19999999999999
    },
    {
      "ayah": 21,
      "text": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ",
      "start_seconds": 101.19999999999999,
      "end_seconds": 108.28
    },
    {
      "ayah": 22,
      "text": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
      "start_seconds": 108.32000000000001,
      "end_seconds": 113.0
    },
    {
      "ayah": 23,
      "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
      "start_seconds": 113.0,
      "end_seconds": 118.0
    },
    {
      "ayah": 24,
      "text": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
      "start_seconds": 118.0,
      "end_seconds": 123.72
    },
    {
      "ayah": 25,
      "text": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
      "start_seconds": 123.72,
      "end_seconds": 129.44
    },
    {
      "ayah": 26,
      "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
      "start_seconds": 129.44,
      "end_seconds": 135.48
    }
  ]
}