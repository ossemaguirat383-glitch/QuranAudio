{
  "surah": 99,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا",
      "start_seconds": 0,
      "end_seconds": 13.8
    },
    {
      "ayah": 3,
      "text": "وَقَالَ ٱلْإِنسَـٰنُ مَا لَهَا",
      "start_seconds": 13.8,
      "end_seconds": 18.48
    },
    {
      "ayah": 4,
      "text": "يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا",
      "start_seconds": 18.48,
      "end_seconds": 23.92
    },
    {
      "ayah": 5,
      "text": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا",
      "start_seconds": 23.92,
      "end_seconds": 28.88
    },
    {
      "ayah": 6,
      "text": "يَوْمَئِذٍ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًا لِّيُرَوْا۟ أَعْمَـٰلَهُمْ",
      "start_seconds": 29.0,
      "end_seconds": 38.12
    },
    {
      "ayah": 7,
      "text": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُۥ",
      "start_seconds": 38.12,
      "end_seconds": 45.0
    },
    {
      "ayah": 8,
      "text": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُۥ",
      "start_seconds": 45.0,
      "end_seconds": 52.76
    }
  ]
}