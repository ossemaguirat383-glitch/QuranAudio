{
  "surah": 93,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
      "start_seconds": 0.0,
      "end_seconds": 4.76
    },
    {
      "ayah": 2,
      "text": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "start_seconds": 4.76,
      "end_seconds": 10.0
    },
    {
      "ayah": 3,
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "start_seconds": 10.0,
      "end_seconds": 15.200000000000001
    },
    {
      "ayah": 4,
      "text": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ",
      "start_seconds": 15.200000000000001,
      "end_seconds": 21.16
    },
    {
      "ayah": 5,
      "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "start_seconds": 21.16,
      "end_seconds": 26.6
    },
    {
      "ayah": 6,
      "text": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ",
      "start_seconds": 26.6,
      "end_seconds": 31.8
    },
    {
      "ayah": 7,
      "text": "وَوَجَدَكَ ضَآلًّا فَهَدَىٰ",
      "start_seconds": 31.8,
      "end_seconds": 38.6
    },
    {
      "ayah": 8,
      "text": "وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ",
      "start_seconds": 38.6,
      "end_seconds": 44.36
    },
    {
      "ayah": 9,
      "text": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
      "start_seconds": 44.36,
      "end_seconds": 49.6
    },
    {
      "ayah": 10,
      "text": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
      "start_seconds": 49.6,
      "end_seconds": 55.8
    },
    {
      "ayah": 11,
      "text": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "start_seconds": 55.8,
      "end_seconds": 61.199999999999996
    }
  ]
}