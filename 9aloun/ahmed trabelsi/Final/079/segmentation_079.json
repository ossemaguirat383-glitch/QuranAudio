{
  "surah": 79,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلنَّـٰزِعَـٰتِ غَرْقًا",
      "start_seconds": 0,
      "end_seconds": 13.68
    },
    {
      "ayah": 3,
      "text": "وَٱلسَّـٰبِحَـٰتِ سَبْحًا",
      "start_seconds": 13.68,
      "end_seconds": 17.36
    },
    {
      "ayah": 4,
      "text": "فَٱلسَّـٰبِقَـٰتِ سَبْقًا",
      "start_seconds": 17.36,
      "end_seconds": 21.04
    },
    {
      "ayah": 5,
      "text": "فَٱلْمُدَبِّرَٰتِ أَمْرًا",
      "start_seconds": 21.04,
      "end_seconds": 25.0
    },
    {
      "ayah": 6,
      "text": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ",
      "start_seconds": 25.0,
      "end_seconds": 28.88
    },
    {
      "ayah": 7,
      "text": "تَتْبَعُهَا ٱلرَّادِفَةُ",
      "start_seconds": 28.88,
      "end_seconds": 32.28
    },
    {
      "ayah": 8,
      "text": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ",
      "start_seconds": 32.28,
      "end_seconds": 37.56
    },
    {
      "ayah": 9,
      "text": "أَبْصَـٰرُهَا خَـٰشِعَةٌ",
      "start_seconds": 37.56,
      "end_seconds": 41.12
    },
    {
      "ayah": 10,
      "text": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
      "start_seconds": 41.12,
      "end_seconds": 49.08
    },
    {
      "ayah": 11,
      "text": "أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً",
      "start_seconds": 49.08,
      "end_seconds": 55.28
    },
    {
      "ayah": 12,
      "text": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
      "start_seconds": 55.32,
      "end_seconds": 61.64
    },
    {
      "ayah": 13,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ",
      "start_seconds": 61.64,
      "end_seconds": 67.6
    },
    {
      "ayah": 14,
      "text": "فَإِذَا هُم بِٱلسَّاهِرَةِ",
      "start_seconds": 67.6,
      "end_seconds": 72.36
    },
    {
      "ayah": 15,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ",
      "start_seconds": 72.36,
      "end_seconds": 76.64
    },
    {
      "ayah": 16,
      "text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
      "start_seconds": 76.64,
      "end_seconds": 84.12
    },
    {
      "ayah": 17,
      "text": "ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ",
      "start_seconds": 84.12,
      "end_seconds": 90.72
    },
    {
      "ayah": 18,
      "text": "فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ",
      "start_seconds": 90.72,
      "end_seconds": 97.28
    },
    {
      "ayah": 19,
      "text": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ",
      "start_seconds": 97.28,
      "end_seconds": 102.56
    },
    {
      "ayah": 20,
      "text": "فَأَرَىٰهُ ٱلْـَٔايَةَ ٱلْكُبْرَىٰ",
      "start_seconds": 102.56,
      "end_seconds": 107.04
    },
    {
      "ayah": 21,
      "text": "فَكَذَّبَ وَعَصَىٰ",
      "start_seconds": 107.04,
      "end_seconds": 110.04
    },
    {
      "ayah": 22,
      "text": "ثُمَّ أَدْبَرَ يَسْعَىٰ",
      "start_seconds": 110.08000000000001,
      "end_seconds": 114.32000000000001
    },
    {
      "ayah": 23,
      "text": "فَحَشَرَ فَنَادَىٰ",
      "start_seconds": 114.32,
      "end_seconds": 117.64
    },
    {
      "ayah": 24,
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ",
      "start_seconds": 117.64,
      "end_seconds": 122.24000000000001
    },
    {
      "ayah": 25,
      "text": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْـَٔاخِرَةِ وَٱلْأُولَىٰٓ",
      "start_seconds": 122.24,
      "end_seconds": 129.24
    },
    {
      "ayah": 26,
      "text": "إِنَّ فِى ذَٰلِكَ لَعِبْرَةً لِّمَن يَخْشَىٰٓ",
      "start_seconds": 129.24,
      "end_seconds": 136.64000000000001
    },
    {
      "ayah": 27,
      "text": "ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا",
      "start_seconds": 136.64,
      "end_seconds": 143.88
    },
    {
      "ayah": 28,
      "text": "رَفَعَ سَمْكَهَا فَسَوَّىٰهَا",
      "start_seconds": 146.07999999999998,
      "end_seconds": 150.67999999999998
    },
    {
      "ayah": 29,
      "text": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا",
      "start_seconds": 150.67999999999998,
      "end_seconds": 156.48
    },
    {
      "ayah": 30,
      "text": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ",
      "start_seconds": 156.48,
      "end_seconds": 161.56
    },
    {
      "ayah": 31,
      "text": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا",
      "start_seconds": 161.68,
      "end_seconds": 168.64000000000001
    },
    {
      "ayah": 32,
      "text": "وَٱلْجِبَالَ أَرْسَىٰهَا",
      "start_seconds": 168.64000000000001,
      "end_seconds": 172.6
    },
    {
      "ayah": 33,
      "text": "مَتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ",
      "start_seconds": 172.6,
      "end_seconds": 177.84
    },
    {
      "ayah": 34,
      "text": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ",
      "start_seconds": 177.84,
      "end_seconds": 187.68
    },
    {
      "ayah": 35,
      "text": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَـٰنُ مَا سَعَىٰ",
      "start_seconds": 187.76,
      "end_seconds": 194.12
    },
    {
      "ayah": 36,
      "text": "وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ",
      "start_seconds": 194.12,
      "end_seconds": 199.56
    },
    {
      "ayah": 37,
      "text": "فَأَمَّا مَن طَغَىٰ",
      "start_seconds": 199.56,
      "end_seconds": 203.76000000000002
    },
    {
      "ayah": 38,
      "text": "وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "start_seconds": 203.76,
      "end_seconds": 208.08
    },
    {
      "ayah": 39,
      "text": "فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ",
      "start_seconds": 208.08,
      "end_seconds": 213.44
    },
    {
      "ayah": 40,
      "text": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ",
      "start_seconds": 213.44,
      "end_seconds": 223.68
    },
    {
      "ayah": 41,
      "text": "فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ",
      "start_seconds": 223.68,
      "end_seconds": 229.96
    },
    {
      "ayah": 42,
      "text": "يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا",
      "start_seconds": 229.96,
      "end_seconds": 236.6
    },
    {
      "ayah": 43,
      "text": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ",
      "start_seconds": 236.6,
      "end_seconds": 242.32
    },
    {
      "ayah": 44,
      "text": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ",
      "start_seconds": 242.35999999999999,
      "end_seconds": 247.2
    },
    {
      "ayah": 45,
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا",
      "start_seconds": 247.2,
      "end_seconds": 257.6
    }
  ]
}