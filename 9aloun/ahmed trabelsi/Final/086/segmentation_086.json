{
  "surah": 86,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "start_seconds": 0,
      "end_seconds": 14.52
    },
    {
      "ayah": 3,
      "text": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "start_seconds": 14.52,
      "end_seconds": 17.84
    },
    {
      "ayah": 4,
      "text": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ",
      "start_seconds": 17.84,
      "end_seconds": 25.2
    },
    {
      "ayah": 5,
      "text": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ",
      "start_seconds": 25.2,
      "end_seconds": 31.96
    },
    {
      "ayah": 6,
      "text": "خُلِقَ مِن مَّآءٍ دَافِقٍ",
      "start_seconds": 31.96,
      "end_seconds": 38.44
    },
    {
      "ayah": 7,
      "text": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "start_seconds": 38.44,
      "end_seconds": 45.879999999999995
    },
    {
      "ayah": 8,
      "text": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ",
      "start_seconds": 45.879999999999995,
      "end_seconds": 51.4
    },
    {
      "ayah": 9,
      "text": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "start_seconds": 51.4,
      "end_seconds": 55.76
    },
    {
      "ayah": 10,
      "text": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ",
      "start_seconds": 55.76,
      "end_seconds": 62.32
    },
    {
      "ayah": 11,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "start_seconds": 62.32,
      "end_seconds": 66.8
    },
    {
      "ayah": 12,
      "text": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "start_seconds": 66.8,
      "end_seconds": 70.32
    },
    {
      "ayah": 13,
      "text": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ",
      "start_seconds": 70.32,
      "end_seconds": 75.08
    },
    {
      "ayah": 14,
      "text": "وَمَا هُوَ بِٱلْهَزْلِ",
      "start_seconds": 75.08,
      "end_seconds": 77.92
    },
    {
      "ayah": 15,
      "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
      "start_seconds": 78.04,
      "end_seconds": 83.08
    },
    {
      "ayah": 16,
      "text": "وَأَكِيدُ كَيْدًا",
      "start_seconds": 83.08,
      "end_seconds": 86.04
    },
    {
      "ayah": 17,
      "text": "فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
      "start_seconds": 86.04,
      "end_seconds": 92.52
    }
  ]
}