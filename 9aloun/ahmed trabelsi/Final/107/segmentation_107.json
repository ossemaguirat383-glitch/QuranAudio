{
  "surah": 107,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "start_seconds": 0,
      "end_seconds": 9.24
    },
    {
      "ayah": 2,
      "text": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "start_seconds": 9.24,
      "end_seconds": 14.08
    },
    {
      "ayah": 3,
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "start_seconds": 14.08,
      "end_seconds": 19.64
    },
    {
      "ayah": 4,
      "text": "فَوَيْلٌ لِّلْمُصَلِّينَ",
      "start_seconds": 19.64,
      "end_seconds": 23.2
    },
    {
      "ayah": 5,
      "text": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "start_seconds": 23.2,
      "end_seconds": 29.2
    },
    {
      "ayah": 6,
      "text": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "start_seconds": 29.2,
      "end_seconds": 34.28
    },
    {
      "ayah": 7,
      "text": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
      "start_seconds": 34.28,
      "end_seconds": 38.04
    }
  ]
}