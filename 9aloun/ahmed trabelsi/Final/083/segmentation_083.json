{
  "surah": 83,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَيْلٌ لِّلْمُطَفِّفِينَ",
      "start_seconds": 0,
      "end_seconds": 7.76
    },
    {
      "ayah": 2,
      "text": "ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ",
      "start_seconds": 7.76,
      "end_seconds": 14.6
    },
    {
      "ayah": 3,
      "text": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ",
      "start_seconds": 14.6,
      "end_seconds": 20.52
    },
    {
      "ayah": 4,
      "text": "أَلَا يَظُنُّ أُو۟لَـٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ",
      "start_seconds": 20.52,
      "end_seconds": 29.32
    },
    {
      "ayah": 5,
      "text": "لِيَوْمٍ عَظِيمٍ",
      "start_seconds": 29.32,
      "end_seconds": 32.12
    },
    {
      "ayah": 6,
      "text": "يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلْعَـٰلَمِينَ",
      "start_seconds": 32.12,
      "end_seconds": 38.44
    },
    {
      "ayah": 7,
      "text": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْفُجَّارِ لَفِى سِجِّينٍ",
      "start_seconds": 38.44,
      "end_seconds": 46.64
    },
    {
      "ayah": 8,
      "text": "وَمَآ أَدْرَىٰكَ مَا سِجِّينٌ",
      "start_seconds": 46.64,
      "end_seconds": 51.879999999999995
    },
    {
      "ayah": 9,
      "text": "كِتَـٰبٌ مَّرْقُومٌ",
      "start_seconds": 51.879999999999995,
      "end_seconds": 55.28
    },
    {
      "ayah": 10,
      "text": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
      "start_seconds": 55.28,
      "end_seconds": 60.480000000000004
    },
    {
      "ayah": 11,
      "text": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ",
      "start_seconds": 60.480000000000004,
      "end_seconds": 65.76
    },
    {
      "ayah": 12,
      "text": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ",
      "start_seconds": 65.76,
      "end_seconds": 73.8
    },
    {
      "ayah": 13,
      "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ",
      "start_seconds": 73.8,
      "end_seconds": 82.32
    },
    {
      "ayah": 14,
      "text": "كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ",
      "start_seconds": 82.32,
      "end_seconds": 91.28
    },
    {
      "ayah": 15,
      "text": "كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ",
      "start_seconds": 91.28,
      "end_seconds": 100.56
    },
    {
      "ayah": 16,
      "text": "ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ",
      "start_seconds": 100.56,
      "end_seconds": 106.35999999999999
    },
    {
      "ayah": 17,
      "text": "ثُمَّ يُقَالُ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ",
      "start_seconds": 106.48,
      "end_seconds": 115.96
    },
    {
      "ayah": 18,
      "text": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْأَبْرَارِ لَفِى عِلِّيِّينَ",
      "start_seconds": 115.96,
      "end_seconds": 124.76
    },
    {
      "ayah": 19,
      "text": "وَمَآ أَدْرَىٰكَ مَا عِلِّيُّونَ",
      "start_seconds": 124.76,
      "end_seconds": 130.56
    },
    {
      "ayah": 20,
      "text": "كِتَـٰبٌ مَّرْقُومٌ",
      "start_seconds": 130.56,
      "end_seconds": 134.24
    },
    {
      "ayah": 21,
      "text": "يَشْهَدُهُ ٱلْمُقَرَّبُونَ",
      "start_seconds": 134.28,
      "end_seconds": 138.08
    },
    {
      "ayah": 22,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ",
      "start_seconds": 138.08,
      "end_seconds": 143.28
    },
    {
      "ayah": 23,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ",
      "start_seconds": 232.23999999999998,
      "end_seconds": 238.11999999999998
    },
    {
      "ayah": 24,
      "text": "تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ",
      "start_seconds": 148.68,
      "end_seconds": 155.28
    },
    {
      "ayah": 25,
      "text": "يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ",
      "start_seconds": 155.28,
      "end_seconds": 160.52
    },
    {
      "ayah": 26,
      "text": "خِتَـٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَـٰفِسُونَ",
      "start_seconds": 162.84,
      "end_seconds": 169.28
    },
    {
      "ayah": 27,
      "text": "وَمِزَاجُهُۥ مِن تَسْنِيمٍ",
      "start_seconds": 169.28,
      "end_seconds": 173.88
    },
    {
      "ayah": 28,
      "text": "عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ",
      "start_seconds": 173.88,
      "end_seconds": 179.52
    },
    {
      "ayah": 29,
      "text": "إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ",
      "start_seconds": 179.52,
      "end_seconds": 189.12
    },
    {
      "ayah": 30,
      "text": "وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ",
      "start_seconds": 189.16,
      "end_seconds": 194.44
    },
    {
      "ayah": 31,
      "text": "وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ",
      "start_seconds": 194.44,
      "end_seconds": 217.92
    },
    {
      "ayah": 33,
      "text": "وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَـٰفِظِينَ",
      "start_seconds": 217.92,
      "end_seconds": 224.35999999999999
    },
    {
      "ayah": 34,
      "text": "فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ",
      "start_seconds": 224.35999999999999,
      "end_seconds": 232.23999999999998
    },
    {
      "ayah": 35,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ",
      "start_seconds": 232.24,
      "end_seconds": 238.12
    },
    {
      "ayah": 36,
      "text": "هَلْ ثُوِّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ",
      "start_seconds": 238.11999999999998,
      "end_seconds": 244.56
    }
  ]
}