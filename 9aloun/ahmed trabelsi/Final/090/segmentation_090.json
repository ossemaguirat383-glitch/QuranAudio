{
  "surah": 90,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِهَـٰذَا ٱلْبَلَدِ",
      "start_seconds": 0,
      "end_seconds": 9.92
    },
    {
      "ayah": 2,
      "text": "وَأَنتَ حِلٌّۢ بِهَـٰذَا ٱلْبَلَدِ",
      "start_seconds": 9.92,
      "end_seconds": 15.72
    },
    {
      "ayah": 3,
      "text": "وَوَالِدٍ وَمَا وَلَدَ",
      "start_seconds": 15.72,
      "end_seconds": 19.8
    },
    {
      "ayah": 4,
      "text": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِى كَبَدٍ",
      "start_seconds": 19.8,
      "end_seconds": 25.52
    },
    {
      "ayah": 5,
      "text": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ",
      "start_seconds": 25.64,
      "end_seconds": 31.72
    },
    {
      "ayah": 6,
      "text": "يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا",
      "start_seconds": 31.72,
      "end_seconds": 36.92
    },
    {
      "ayah": 7,
      "text": "أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ",
      "start_seconds": 36.92,
      "end_seconds": 42.2
    },
    {
      "ayah": 8,
      "text": "أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ",
      "start_seconds": 42.2,
      "end_seconds": 46.92
    },
    {
      "ayah": 9,
      "text": "وَلِسَانًا وَشَفَتَيْنِ",
      "start_seconds": 46.92,
      "end_seconds": 51.44
    },
    {
      "ayah": 10,
      "text": "وَهَدَيْنَـٰهُ ٱلنَّجْدَيْنِ",
      "start_seconds": 51.56,
      "end_seconds": 56.08
    },
    {
      "ayah": 11,
      "text": "فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ",
      "start_seconds": 56.08,
      "end_seconds": 64.75999999999999
    },
    {
      "ayah": 13,
      "text": "فَكُّ رَقَبَةٍ",
      "start_seconds": 64.75999999999999,
      "end_seconds": 67.16
    },
    {
      "ayah": 14,
      "text": "أَوْ إِطْعَـٰمٌ فِى يَوْمٍ ذِى مَسْغَبَةٍ",
      "start_seconds": 67.16,
      "end_seconds": 74.36
    },
    {
      "ayah": 15,
      "text": "يَتِيمًا ذَا مَقْرَبَةٍ",
      "start_seconds": 74.36,
      "end_seconds": 78.84
    },
    {
      "ayah": 16,
      "text": "أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ",
      "start_seconds": 78.84,
      "end_seconds": 84.04
    },
    {
      "ayah": 17,
      "text": "ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ",
      "start_seconds": 84.04,
      "end_seconds": 96.64
    },
    {
      "ayah": 18,
      "text": "أُو۟لَـٰٓئِكَ أَصْحَـٰبُ ٱلْمَيْمَنَةِ",
      "start_seconds": 96.64,
      "end_seconds": 102.24
    },
    {
      "ayah": 19,
      "text": "وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَـٰتِنَا هُمْ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ",
      "start_seconds": 102.24,
      "end_seconds": 110.60000000000001
    },
    {
      "ayah": 20,
      "text": "عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌۢ",
      "start_seconds": 110.60000000000001,
      "end_seconds": 115.12
    }
  ]
}