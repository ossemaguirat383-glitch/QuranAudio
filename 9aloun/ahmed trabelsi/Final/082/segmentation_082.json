{
  "surah": 82,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
      "start_seconds": 0,
      "end_seconds": 8.44
    },
    {
      "ayah": 2,
      "text": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ",
      "start_seconds": 8.44,
      "end_seconds": 12.52
    },
    {
      "ayah": 3,
      "text": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
      "start_seconds": 12.52,
      "end_seconds": 15.76
    },
    {
      "ayah": 4,
      "text": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ",
      "start_seconds": 15.76,
      "end_seconds": 19.04
    },
    {
      "ayah": 5,
      "text": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ",
      "start_seconds": 19.04,
      "end_seconds": 25.080000000000002
    },
    {
      "ayah": 6,
      "text": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
      "start_seconds": 25.2,
      "end_seconds": 33.44
    },
    {
      "ayah": 7,
      "text": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
      "start_seconds": 33.44,
      "end_seconds": 38.4
    },
    {
      "ayah": 8,
      "text": "فِىٓ أَىِّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ",
      "start_seconds": 38.4,
      "end_seconds": 46.32
    },
    {
      "ayah": 9,
      "text": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
      "start_seconds": 46.32,
      "end_seconds": 51.2
    },
    {
      "ayah": 10,
      "text": "وَإِنَّ عَلَيْكُمْ لَحَـٰفِظِينَ",
      "start_seconds": 51.28,
      "end_seconds": 56.160000000000004
    },
    {
      "ayah": 11,
      "text": "كِرَامًا كَـٰتِبِينَ",
      "start_seconds": 56.160000000000004,
      "end_seconds": 59.88
    },
    {
      "ayah": 12,
      "text": "يَعْلَمُونَ مَا تَفْعَلُونَ",
      "start_seconds": 59.88,
      "end_seconds": 63.800000000000004
    },
    {
      "ayah": 13,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ",
      "start_seconds": 63.800000000000004,
      "end_seconds": 68.92
    },
    {
      "ayah": 14,
      "text": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ",
      "start_seconds": 68.92,
      "end_seconds": 74.24000000000001
    },
    {
      "ayah": 15,
      "text": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ",
      "start_seconds": 74.24000000000001,
      "end_seconds": 78.2
    },
    {
      "ayah": 16,
      "text": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ",
      "start_seconds": 78.2,
      "end_seconds": 84.04
    },
    {
      "ayah": 17,
      "text": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
      "start_seconds": 84.04,
      "end_seconds": 89.68
    },
    {
      "ayah": 18,
      "text": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
      "start_seconds": 89.68,
      "end_seconds": 96.84
    },
    {
      "ayah": 19,
      "text": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْـًٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍ لِّلَّهِ",
      "start_seconds": 96.84,
      "end_seconds": 103.68
    }
  ]
}