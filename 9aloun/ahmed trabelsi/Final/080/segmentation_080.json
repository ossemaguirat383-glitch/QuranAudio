{
  "surah": 80,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ",
      "start_seconds": 0.0,
      "end_seconds": 7.7
    },
    {
      "ayah": 2,
      "text": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
      "start_seconds": 7.7,
      "end_seconds": 12.88
    },
    {
      "ayah": 3,
      "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "start_seconds": 12.88,
      "end_seconds": 18.6
    },
    {
      "ayah": 4,
      "text": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
      "start_seconds": 18.6,
      "end_seconds": 24.7
    },
    {
      "ayah": 5,
      "text": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
      "start_seconds": 24.7,
      "end_seconds": 28.88
    },
    {
      "ayah": 6,
      "text": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
      "start_seconds": 28.88,
      "end_seconds": 33.16
    },
    {
      "ayah": 7,
      "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "start_seconds": 33.16,
      "end_seconds": 38.28
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
      "start_seconds": 38.28,
      "end_seconds": 45.8
    },
    {
      "ayah": 9,
      "text": "وَهُوَ يَخْشَىٰ",
      "start_seconds": 45.8,
      "end_seconds": 48.16
    },
    {
      "ayah": 10,
      "text": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
      "start_seconds": 48.16,
      "end_seconds": 52.519999999999996
    },
    {
      "ayah": 11,
      "text": "كَلَّآ إِنَّهَا تَذْكِرَةٌ",
      "start_seconds": 52.519999999999996,
      "end_seconds": 58.64
    },
    {
      "ayah": 12,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ",
      "start_seconds": 58.64,
      "end_seconds": 63.4
    },
    {
      "ayah": 13,
      "text": "فِى صُحُفٍ مُّكَرَّمَةٍ",
      "start_seconds": 63.4,
      "end_seconds": 67.56
    },
    {
      "ayah": 14,
      "text": "مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ",
      "start_seconds": 67.56,
      "end_seconds": 72.24
    },
    {
      "ayah": 15,
      "text": "بِأَيْدِى سَفَرَةٍ",
      "start_seconds": 72.24,
      "end_seconds": 75.12
    },
    {
      "ayah": 16,
      "text": "كِرَامٍۭ بَرَرَةٍ",
      "start_seconds": 75.12,
      "end_seconds": 78.6
    },
    {
      "ayah": 17,
      "text": "قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ",
      "start_seconds": 78.6,
      "end_seconds": 86.28
    },
    {
      "ayah": 18,
      "text": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
      "start_seconds": 86.28,
      "end_seconds": 90.0
    },
    {
      "ayah": 19,
      "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
      "start_seconds": 90.0,
      "end_seconds": 95.6
    },
    {
      "ayah": 20,
      "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
      "start_seconds": 95.6,
      "end_seconds": 100.0
    },
    {
      "ayah": 21,
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
      "start_seconds": 100.0,
      "end_seconds": 105.24
    },
    {
      "ayah": 22,
      "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
      "start_seconds": 105.24,
      "end_seconds": 111.75999999999999
    },
    {
      "ayah": 23,
      "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
      "start_seconds": 111.76,
      "end_seconds": 117.76
    },
    {
      "ayah": 24,
      "text": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ",
      "start_seconds": 117.76,
      "end_seconds": 124.04
    },
    {
      "ayah": 25,
      "text": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا",
      "start_seconds": 124.04,
      "end_seconds": 130.16
    },
    {
      "ayah": 26,
      "text": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا",
      "start_seconds": 130.16,
      "end_seconds": 135.08
    },
    {
      "ayah": 27,
      "text": "فَأَنۢبَتْنَا فِيهَا حَبًّا",
      "start_seconds": 135.08,
      "end_seconds": 140.04000000000002
    },
    {
      "ayah": 28,
      "text": "وَعِنَبًا وَقَضْبًا",
      "start_seconds": 140.07999999999998,
      "end_seconds": 143.64
    },
    {
      "ayah": 29,
      "text": "وَزَيْتُونًا وَنَخْلًا",
      "start_seconds": 143.64,
      "end_seconds": 147.84
    },
    {
      "ayah": 30,
      "text": "وَحَدَآئِقَ غُلْبًا",
      "start_seconds": 147.84,
      "end_seconds": 151.92
    },
    {
      "ayah": 31,
      "text": "وَفَـٰكِهَةً وَأَبًّا",
      "start_seconds": 151.92,
      "end_seconds": 156.0
    },
    {
      "ayah": 32,
      "text": "مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ",
      "start_seconds": 156.0,
      "end_seconds": 160.84
    },
    {
      "ayah": 33,
      "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
      "start_seconds": 160.84,
      "end_seconds": 168.68
    },
    {
      "ayah": 34,
      "text": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
      "start_seconds": 168.68,
      "end_seconds": 173.24
    },
    {
      "ayah": 35,
      "text": "وَأُمِّهِۦ وَأَبِيهِ",
      "start_seconds": 173.24,
      "end_seconds": 176.96
    },
    {
      "ayah": 36,
      "text": "وَصَـٰحِبَتِهِۦ وَبَنِيهِ",
      "start_seconds": 176.96,
      "end_seconds": 180.72
    },
    {
      "ayah": 37,
      "text": "لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
      "start_seconds": 180.72,
      "end_seconds": 189.44
    },
    {
      "ayah": 38,
      "text": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
      "start_seconds": 189.44,
      "end_seconds": 194.72
    },
    {
      "ayah": 39,
      "text": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
      "start_seconds": 194.76,
      "end_seconds": 198.88
    },
    {
      "ayah": 40,
      "text": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
      "start_seconds": 198.88,
      "end_seconds": 204.92
    },
    {
      "ayah": 41,
      "text": "تَرْهَقُهَا قَتَرَةٌ",
      "start_seconds": 204.92,
      "end_seconds": 207.76
    },
    {
      "ayah": 42,
      "text": "أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
      "start_seconds": 207.76,
      "end_seconds": 213.4
    }
  ]
}