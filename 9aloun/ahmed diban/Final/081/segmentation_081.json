{
  "surah": 81,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ",
      "start_seconds": 0,
      "end_seconds": 5.24
    },
    {
      "ayah": 2,
      "text": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
      "start_seconds": 5.24,
      "end_seconds": 8.52
    },
    {
      "ayah": 3,
      "text": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
      "start_seconds": 8.52,
      "end_seconds": 11.0
    },
    {
      "ayah": 4,
      "text": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
      "start_seconds": 11.0,
      "end_seconds": 13.56
    },
    {
      "ayah": 5,
      "text": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
      "start_seconds": 13.88,
      "end_seconds": 16.12
    },
    {
      "ayah": 6,
      "text": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
      "start_seconds": 16.12,
      "end_seconds": 18.52
    },
    {
      "ayah": 7,
      "text": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
      "start_seconds": 18.8,
      "end_seconds": 22.28
    },
    {
      "ayah": 8,
      "text": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
      "start_seconds": 22.28,
      "end_seconds": 25.240000000000002
    },
    {
      "ayah": 9,
      "text": "بِأَىِّ ذَنۢبٍ قُتِلَتْ",
      "start_seconds": 25.240000000000002,
      "end_seconds": 28.52
    },
    {
      "ayah": 10,
      "text": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
      "start_seconds": 28.759999999999998,
      "end_seconds": 31.4
    },
    {
      "ayah": 11,
      "text": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
      "start_seconds": 31.4,
      "end_seconds": 36.2
    },
    {
      "ayah": 12,
      "text": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
      "start_seconds": 36.2,
      "end_seconds": 38.56
    },
    {
      "ayah": 13,
      "text": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
      "start_seconds": 38.56,
      "end_seconds": 42.28
    },
    {
      "ayah": 14,
      "text": "عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ",
      "start_seconds": 42.28,
      "end_seconds": 47.32
    },
    {
      "ayah": 15,
      "text": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
      "start_seconds": 47.32,
      "end_seconds": 50.28
    },
    {
      "ayah": 16,
      "text": "ٱلْجَوَارِ ٱلْكُنَّسِ",
      "start_seconds": 50.28,
      "end_seconds": 52.760000000000005
    },
    {
      "ayah": 17,
      "text": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
      "start_seconds": 52.760000000000005,
      "end_seconds": 55.120000000000005
    },
    {
      "ayah": 18,
      "text": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
      "start_seconds": 55.120000000000005,
      "end_seconds": 58.08
    },
    {
      "ayah": 19,
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ",
      "start_seconds": 58.12,
      "end_seconds": 64.36
    },
    {
      "ayah": 20,
      "text": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ",
      "start_seconds": 64.36,
      "end_seconds": 69.36
    },
    {
      "ayah": 21,
      "text": "مُّطَاعٍ ثَمَّ أَمِينٍ",
      "start_seconds": 69.36,
      "end_seconds": 73.84
    },
    {
      "ayah": 22,
      "text": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
      "start_seconds": 73.84,
      "end_seconds": 77.88
    },
    {
      "ayah": 23,
      "text": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
      "start_seconds": 77.88,
      "end_seconds": 83.32
    },
    {
      "ayah": 24,
      "text": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ",
      "start_seconds": 83.32,
      "end_seconds": 88.32
    },
    {
      "ayah": 25,
      "text": "وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ",
      "start_seconds": 88.32,
      "end_seconds": 93.19999999999999
    },
    {
      "ayah": 26,
      "text": "فَأَيْنَ تَذْهَبُونَ",
      "start_seconds": 93.19999999999999,
      "end_seconds": 96.39999999999999
    },
    {
      "ayah": 27,
      "text": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ",
      "start_seconds": 96.39999999999999,
      "end_seconds": 100.6
    },
    {
      "ayah": 28,
      "text": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
      "start_seconds": 100.6,
      "end_seconds": 109.52
    },
    {
      "ayah": 29,
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ",
      "start_seconds": 109.52,
      "end_seconds": 119.47999999999999
    }
  ]
}