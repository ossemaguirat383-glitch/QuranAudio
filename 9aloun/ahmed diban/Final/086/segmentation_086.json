{
  "surah": 86,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "start_seconds": 0,
      "end_seconds": 12.4
    },
    {
      "ayah": 4,
      "text": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ",
      "start_seconds": 12.4,
      "end_seconds": 17.88
    },
    {
      "ayah": 5,
      "text": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ",
      "start_seconds": 17.88,
      "end_seconds": 23.44
    },
    {
      "ayah": 6,
      "text": "خُلِقَ مِن مَّآءٍ دَافِقٍ",
      "start_seconds": 23.44,
      "end_seconds": 28.04
    },
    {
      "ayah": 7,
      "text": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "start_seconds": 28.119999999999997,
      "end_seconds": 33.76
    },
    {
      "ayah": 8,
      "text": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ",
      "start_seconds": 33.76,
      "end_seconds": 38.24
    },
    {
      "ayah": 9,
      "text": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "start_seconds": 38.24,
      "end_seconds": 43.04
    },
    {
      "ayah": 10,
      "text": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ",
      "start_seconds": 43.04,
      "end_seconds": 48.599999999999994
    },
    {
      "ayah": 11,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "start_seconds": 48.599999999999994,
      "end_seconds": 52.08
    },
    {
      "ayah": 12,
      "text": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "start_seconds": 52.08,
      "end_seconds": 54.68
    },
    {
      "ayah": 13,
      "text": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ",
      "start_seconds": 54.72,
      "end_seconds": 59.12
    },
    {
      "ayah": 14,
      "text": "وَمَا هُوَ بِٱلْهَزْلِ",
      "start_seconds": 59.12,
      "end_seconds": 61.48
    },
    {
      "ayah": 15,
      "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
      "start_seconds": 61.48,
      "end_seconds": 66.36
    },
    {
      "ayah": 16,
      "text": "وَأَكِيدُ كَيْدًا",
      "start_seconds": 66.36,
      "end_seconds": 68.84
    }
  ]
}