{
  "surah": 88,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ",
      "start_seconds": 0,
      "end_seconds": 6.6000000000000005
    },
    {
      "ayah": 2,
      "text": "وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ",
      "start_seconds": 6.6000000000000005,
      "end_seconds": 10.120000000000001
    },
    {
      "ayah": 3,
      "text": "عَامِلَةٌ نَّاصِبَةٌ",
      "start_seconds": 10.120000000000001,
      "end_seconds": 13.08
    },
    {
      "ayah": 4,
      "text": "تَصْلَىٰ نَارًا حَامِيَةً",
      "start_seconds": 13.08,
      "end_seconds": 15.92
    },
    {
      "ayah": 5,
      "text": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ",
      "start_seconds": 15.92,
      "end_seconds": 19.04
    },
    {
      "ayah": 6,
      "text": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
      "start_seconds": 19.04,
      "end_seconds": 24.72
    },
    {
      "ayah": 7,
      "text": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ",
      "start_seconds": 24.72,
      "end_seconds": 30.84
    },
    {
      "ayah": 8,
      "text": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
      "start_seconds": 30.84,
      "end_seconds": 34.92
    },
    {
      "ayah": 9,
      "text": "لِّسَعْيِهَا رَاضِيَةٌ",
      "start_seconds": 34.92,
      "end_seconds": 37.32
    },
    {
      "ayah": 10,
      "text": "فِى جَنَّةٍ عَالِيَةٍ",
      "start_seconds": 37.32,
      "end_seconds": 40.56
    },
    {
      "ayah": 11,
      "text": "لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً",
      "start_seconds": 40.56,
      "end_seconds": 44.36
    },
    {
      "ayah": 12,
      "text": "فِيهَا عَيْنٌ جَارِيَةٌ",
      "start_seconds": 44.36,
      "end_seconds": 48.519999999999996
    },
    {
      "ayah": 13,
      "text": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
      "start_seconds": 48.519999999999996,
      "end_seconds": 52.76
    },
    {
      "ayah": 14,
      "text": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
      "start_seconds": 52.8,
      "end_seconds": 55.76
    },
    {
      "ayah": 15,
      "text": "وَنَمَارِقُ مَصْفُوفَةٌ",
      "start_seconds": 55.76,
      "end_seconds": 58.879999999999995
    },
    {
      "ayah": 16,
      "text": "وَزَرَابِىُّ مَبْثُوثَةٌ",
      "start_seconds": 58.879999999999995,
      "end_seconds": 61.839999999999996
    },
    {
      "ayah": 17,
      "text": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
      "start_seconds": 65.48,
      "end_seconds": 68.48
    },
    {
      "ayah": 18,
      "text": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
      "start_seconds": 68.48,
      "end_seconds": 73.36
    },
    {
      "ayah": 19,
      "text": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
      "start_seconds": 73.36,
      "end_seconds": 76.6
    },
    {
      "ayah": 20,
      "text": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
      "start_seconds": 76.6,
      "end_seconds": 79.64
    },
    {
      "ayah": 21,
      "text": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ",
      "start_seconds": 79.68,
      "end_seconds": 86.08
    },
    {
      "ayah": 22,
      "text": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
      "start_seconds": 86.08,
      "end_seconds": 89.48
    },
    {
      "ayah": 23,
      "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
      "start_seconds": 89.48,
      "end_seconds": 93.32
    },
    {
      "ayah": 24,
      "text": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
      "start_seconds": 93.32,
      "end_seconds": 97.92
    },
    {
      "ayah": 25,
      "text": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
      "start_seconds": 97.92,
      "end_seconds": 101.76
    },
    {
      "ayah": 26,
      "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
      "start_seconds": 101.76,
      "end_seconds": 109.56
    }
  ]
}