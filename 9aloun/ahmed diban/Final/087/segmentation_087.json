{
  "surah": 87,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
      "start_seconds": 0,
      "end_seconds": 17.240000000000002
    },
    {
      "ayah": 6,
      "text": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "start_seconds": 17.240000000000002,
      "end_seconds": 24.68
    },
    {
      "ayah": 7,
      "text": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "start_seconds": 24.68,
      "end_seconds": 30.4
    },
    {
      "ayah": 8,
      "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "start_seconds": 30.4,
      "end_seconds": 37.36
    },
    {
      "ayah": 10,
      "text": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "start_seconds": 37.36,
      "end_seconds": 43.68
    },
    {
      "ayah": 12,
      "text": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "start_seconds": 43.68,
      "end_seconds": 47.6
    },
    {
      "ayah": 13,
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "start_seconds": 47.6,
      "end_seconds": 52.480000000000004
    },
    {
      "ayah": 14,
      "text": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "start_seconds": 52.6,
      "end_seconds": 60.2
    },
    {
      "ayah": 15,
      "text": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
      "start_seconds": 60.2,
      "end_seconds": 60.199999999999996
    },
    {
      "ayah": 16,
      "text": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "start_seconds": 60.199999999999996,
      "end_seconds": 64.28
    },
    {
      "ayah": 17,
      "text": "وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ",
      "start_seconds": 64.28,
      "end_seconds": 68.88
    },
    {
      "ayah": 18,
      "text": "إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
      "start_seconds": 68.88,
      "end_seconds": 73.88
    },
    {
      "ayah": 19,
      "text": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
      "start_seconds": 73.88,
      "end_seconds": 79.16
    }
  ]
}