  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "start_seconds": 0,
      "end_seconds": 5.72
    },
    {
      "ayah": 2,
      "text": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "start_seconds": 5.72,
      "end_seconds": 9.92
    },
    {
      "ayah": 3,
      "text": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
      "start_seconds": 9.92,
      "end_seconds": 13.68
    },
    {
      "ayah": 4,
      "text": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "start_seconds": 13.68,
      "end_seconds": 16.4
    },
    {
      "ayah": 5,
      "text": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "start_seconds": 16.4,
      "end_seconds": 24.76
    },
    {
      "ayah": 7,
      "text": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
      "start_seconds": 24.76,
      "end_seconds": 28.44
    },
    {
      "ayah": 8,
      "text": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
      "start_seconds": 28.44,
      "end_seconds": 31.36
    }
  ]
