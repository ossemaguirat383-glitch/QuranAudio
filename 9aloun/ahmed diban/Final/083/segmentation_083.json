{
  "surah": 83,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَيْلٌ لِّلْمُطَفِّفِينَ",
      "start_seconds": 0,
      "end_seconds": 6.2
    },
    {
      "ayah": 2,
      "text": "ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ",
      "start_seconds": 6.2,
      "end_seconds": 12.2
    },
    {
      "ayah": 3,
      "text": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ",
      "start_seconds": 12.200000000000001,
      "end_seconds": 17.900000000000002
    },
    {
      "ayah": 4,
      "text": "أَلَا يَظُنُّ أُو۟لَـٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ",
      "start_seconds": 17.900000000000002,
      "end_seconds": 23.900000000000002
    },
    {
      "ayah": 5,
      "text": "لِيَوْمٍ عَظِيمٍ",
      "start_seconds": 23.900000000000002,
      "end_seconds": 26.7
    },
    {
      "ayah": 6,
      "text": "يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلْعَـٰلَمِينَ",
      "start_seconds": 26.7,
      "end_seconds": 32.3
    },
    {
      "ayah": 7,
      "text": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْفُجَّارِ لَفِى سِجِّينٍ",
      "start_seconds": 32.3,
      "end_seconds": 38.5
    },
    {
      "ayah": 8,
      "text": "وَمَآ أَدْرَىٰكَ مَا سِجِّينٌ",
      "start_seconds": 38.5,
      "end_seconds": 42.9
    },
    {
      "ayah": 9,
      "text": "كِتَـٰبٌ مَّرْقُومٌ",
      "start_seconds": 42.9,
      "end_seconds": 46.5
    },
    {
      "ayah": 10,
      "text": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
      "start_seconds": 46.5,
      "end_seconds": 50.7
    },
    {
      "ayah": 11,
      "text": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ",
      "start_seconds": 50.7,
      "end_seconds": 54.9
    },
    {
      "ayah": 12,
      "text": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ",
      "start_seconds": 54.9,
      "end_seconds": 60.8
    },
    {
      "ayah": 13,
      "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَـٰتُنَا قَالَ أَسَـٰطِيرُ ٱلْأَوَّلِينَ",
      "start_seconds": 60.8,
      "end_seconds": 68.5
    },
    {
      "ayah": 14,
      "text": "كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ",
      "start_seconds": 68.5,
      "end_seconds": 75.5
    },
    {
      "ayah": 15,
      "text": "كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ",
      "start_seconds": 75.5,
      "end_seconds": 83.5
    },
    {
      "ayah": 16,
      "text": "ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ",
      "start_seconds": 83.5,
      "end_seconds": 88.7
    },
    {
      "ayah": 17,
      "text": "ثُمَّ يُقَالُ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ",
      "start_seconds": 88.7,
      "end_seconds": 97.1
    },
    {
      "ayah": 18,
      "text": "كَلَّآ إِنَّ كِتَـٰبَ ٱلْأَبْرَارِ لَفِى عِلِّيِّينَ",
      "start_seconds": 97.1,
      "end_seconds": 103.5
    },
    {
      "ayah": 19,
      "text": "وَمَآ أَدْرَىٰكَ مَا عِلِّيُّونَ",
      "start_seconds": 103.5,
      "end_seconds": 108.1
    },
    {
      "ayah": 20,
      "text": "كِتَـٰبٌ مَّرْقُومٌ",
      "start_seconds": 108.1,
      "end_seconds": 112.9
    },
    {
      "ayah": 21,
      "text": "يَشْهَدُهُ ٱلْمُقَرَّبُونَ",
      "start_seconds": 112.9,
      "end_seconds": 117.3
    },
    {
      "ayah": 22,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ",
      "start_seconds": 117.30000000000001,
      "end_seconds": 121.5
    },
    {
      "ayah": 23,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ",
      "start_seconds": 121.5,
      "end_seconds": 126.30000000000001
    },
    {
      "ayah": 24,
      "text": "تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ",
      "start_seconds": 126.30000000000001,
      "end_seconds": 131.9
    },
    {
      "ayah": 25,
      "text": "يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ",
      "start_seconds": 131.9,
      "end_seconds": 137.5
    },
    {
      "ayah": 26,
      "text": "خِتَـٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَـٰفِسُونَ",
      "start_seconds": 139.7,
      "end_seconds": 145.7
    },
    {
      "ayah": 27,
      "text": "وَمِزَاجُهُۥ مِن تَسْنِيمٍ",
      "start_seconds": 145.7,
      "end_seconds": 150.7
    },
    {
      "ayah": 28,
      "text": "عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ",
      "start_seconds": 150.7,
      "end_seconds": 155.89999999999998
    },
    {
      "ayah": 29,
      "text": "إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ",
      "start_seconds": 155.89999999999998,
      "end_seconds": 163.7
    },
    {
      "ayah": 30,
      "text": "وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ",
      "start_seconds": 163.7,
      "end_seconds": 168.29999999999998
    },
    {
      "ayah": 31,
      "text": "وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ",
      "start_seconds": 168.29999999999998,
      "end_seconds": 175.9
    },
    {
      "ayah": 32,
      "text": "وَإِذَا رَأَوْهُمْ قَالُوٓا۟ إِنَّ هَـٰٓؤُلَآءِ لَضَآلُّونَ",
      "start_seconds": 175.9,
      "end_seconds": 185.9
    },
    {
      "ayah": 33,
      "text": "وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَـٰفِظِينَ",
      "start_seconds": 185.9,
      "end_seconds": 190.9
    },
    {
      "ayah": 34,
      "text": "فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ",
      "start_seconds": 190.9,
      "end_seconds": 197.5
    },
    {
      "ayah": 35,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ",
      "start_seconds": 197.5,
      "end_seconds": 204.5
    },
    {
      "ayah": 36,
      "text": "هَلْ ثُوِّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ",
      "start_seconds": 204.5,
      "end_seconds": 212.9
    }
  ]
}