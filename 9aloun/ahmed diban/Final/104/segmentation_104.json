{
  "surah": 104,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ",
      "start_seconds": 0,
      "end_seconds": 10.68
    },
    {
      "ayah": 3,
      "text": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
      "start_seconds": 10.68,
      "end_seconds": 15.280000000000001
    },
    {
      "ayah": 4,
      "text": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
      "start_seconds": 15.280000000000001,
      "end_seconds": 20.44
    },
    {
      "ayah": 5,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
      "start_seconds": 20.44,
      "end_seconds": 23.48
    },
    {
      "ayah": 6,
      "text": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
      "start_seconds": 23.48,
      "end_seconds": 26.32
    },
    {
      "ayah": 7,
      "text": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
      "start_seconds": 26.52,
      "end_seconds": 30.28
    },
    {
      "ayah": 8,
      "text": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ",
      "start_seconds": 30.28,
      "end_seconds": 34.36
    },
    {
      "ayah": 9,
      "text": "فِى عَمَدٍ مُّمَدَّدَةٍۭ",
      "start_seconds": 34.36,
      "end_seconds": 39.2
    }
  ]
}