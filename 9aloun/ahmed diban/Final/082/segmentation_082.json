{
  "surah": 82,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
      "start_seconds": 0.0,
      "end_seconds": 11.0
    },
    {
      "ayah": 3,
      "text": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
      "start_seconds": 11.0,
      "end_seconds": 16.36
    },
    {
      "ayah": 5,
      "text": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ",
      "start_seconds": 16.36,
      "end_seconds": 22.6
    },
    {
      "ayah": 6,
      "text": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
      "start_seconds": 22.6,
      "end_seconds": 31.32
    },
    {
      "ayah": 7,
      "text": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
      "start_seconds": 31.32,
      "end_seconds": 36.08
    },
    {
      "ayah": 8,
      "text": "فِىٓ أَىِّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ",
      "start_seconds": 36.08,
      "end_seconds": 41.6
    },
    {
      "ayah": 9,
      "text": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
      "start_seconds": 41.6,
      "end_seconds": 45.84
    },
    {
      "ayah": 10,
      "text": "وَإِنَّ عَلَيْكُمْ لَحَـٰفِظِينَ",
      "start_seconds": 45.84,
      "end_seconds": 50.84
    },
    {
      "ayah": 11,
      "text": "كِرَامًا كَـٰتِبِينَ",
      "start_seconds": 50.88,
      "end_seconds": 54.96
    },
    {
      "ayah": 12,
      "text": "يَعْلَمُونَ مَا تَفْعَلُونَ",
      "start_seconds": 54.96,
      "end_seconds": 58.160000000000004
    },
    {
      "ayah": 13,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ",
      "start_seconds": 58.160000000000004,
      "end_seconds": 62.64
    },
    {
      "ayah": 14,
      "text": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ",
      "start_seconds": 62.64,
      "end_seconds": 67.2
    },
    {
      "ayah": 15,
      "text": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ",
      "start_seconds": 67.2,
      "end_seconds": 70.96000000000001
    },
    {
      "ayah": 16,
      "text": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ",
      "start_seconds": 70.96000000000001,
      "end_seconds": 77.28
    },
    {
      "ayah": 17,
      "text": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
      "start_seconds": 77.32000000000001,
      "end_seconds": 80.8
    },
    {
      "ayah": 18,
      "text": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
      "start_seconds": 80.8,
      "end_seconds": 86.76
    },
    {
      "ayah": 19,
      "text": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْـًٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍ لِّلَّهِ",
      "start_seconds": 86.76,
      "end_seconds": 92.36
    }
  ]
}