{
  "surah": 91,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا",
      "start_seconds": 0,
      "end_seconds": 20.8
    },
    {
      "ayah": 8,
      "text": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا",
      "start_seconds": 20.8,
      "end_seconds": 28.6
    },
    {
      "ayah": 9,
      "text": "قَدْ أَفْلَحَ مَن زَكَّىٰهَا",
      "start_seconds": 28.6,
      "end_seconds": 38.2
    },
    {
      "ayah": 11,
      "text": "كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ",
      "start_seconds": 38.2,
      "end_seconds": 45.4
    },
    {
      "ayah": 12,
      "text": "إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا",
      "start_seconds": 45.4,
      "end_seconds": 45.400000000000006
    },
    {
      "ayah": 13,
      "text": "فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَـٰهَا",
      "start_seconds": 45.400000000000006,
      "end_seconds": 52.52
    },
    {
      "ayah": 14,
      "text": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا",
      "start_seconds": 52.64,
      "end_seconds": 64.04
    },
    {
      "ayah": 15,
      "text": "وَلَا يَخَافُ عُقْبَـٰهَا",
      "start_seconds": 64.04,
      "end_seconds": 68.92
    }
  ]
}