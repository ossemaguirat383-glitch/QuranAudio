{
  "surah": 90,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِهَـٰذَا ٱلْبَلَدِ",
      "start_seconds": 0,
      "end_seconds": 6.0
    },
    {
      "ayah": 2,
      "text": "وَأَنتَ حِلٌّۢ بِهَـٰذَا ٱلْبَلَدِ",
      "start_seconds": 6.0,
      "end_seconds": 9.8
    },
    {
      "ayah": 3,
      "text": "وَوَالِدٍ وَمَا وَلَدَ",
      "start_seconds": 9.8,
      "end_seconds": 12.68
    },
    {
      "ayah": 4,
      "text": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِى كَبَدٍ",
      "start_seconds": 12.68,
      "end_seconds": 17.0
    },
    {
      "ayah": 5,
      "text": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌ",
      "start_seconds": 17.0,
      "end_seconds": 21.92
    },
    {
      "ayah": 6,
      "text": "يَقُولُ أَهْلَكْتُ مَالًا لُّبَدًا",
      "start_seconds": 21.92,
      "end_seconds": 25.88
    },
    {
      "ayah": 7,
      "text": "أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ",
      "start_seconds": 25.88,
      "end_seconds": 29.56
    },
    {
      "ayah": 8,
      "text": "أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ",
      "start_seconds": 29.56,
      "end_seconds": 33.839999999999996
    },
    {
      "ayah": 9,
      "text": "وَلِسَانًا وَشَفَتَيْنِ",
      "start_seconds": 33.84,
      "end_seconds": 37.32
    },
    {
      "ayah": 10,
      "text": "وَهَدَيْنَـٰهُ ٱلنَّجْدَيْنِ",
      "start_seconds": 37.32,
      "end_seconds": 41.0
    },
    {
      "ayah": 11,
      "text": "فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ",
      "start_seconds": 41.0,
      "end_seconds": 43.6
    },
    {
      "ayah": 12,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْعَقَبَةُ",
      "start_seconds": 43.6,
      "end_seconds": 52.96
    },
    {
      "ayah": 15,
      "text": "يَتِيمًا ذَا مَقْرَبَةٍ",
      "start_seconds": 52.96,
      "end_seconds": 55.96
    },
    {
      "ayah": 16,
      "text": "أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ",
      "start_seconds": 56.0,
      "end_seconds": 59.64
    },
    {
      "ayah": 17,
      "text": "ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ وَتَوَاصَوْا۟ بِٱلصَّبْرِ وَتَوَاصَوْا۟ بِٱلْمَرْحَمَةِ",
      "start_seconds": 59.64,
      "end_seconds": 72.28
    },
    {
      "ayah": 18,
      "text": "أُو۟لَـٰٓئِكَ أَصْحَـٰبُ ٱلْمَيْمَنَةِ",
      "start_seconds": 72.28,
      "end_seconds": 76.44
    },
    {
      "ayah": 19,
      "text": "وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَـٰتِنَا هُمْ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ",
      "start_seconds": 76.44,
      "end_seconds": 83.12
    },
    {
      "ayah": 20,
      "text": "عَلَيْهِمْ نَارٌ مُّؤْصَدَةٌۢ",
      "start_seconds": 83.12,
      "end_seconds": 89.56
    }
  ]
}