{
  "surah": 80,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ",
      "start_seconds": 0.0,
      "end_seconds": 3.3
    },
    {
      "ayah": 2,
      "text": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
      "start_seconds": 3.3000000000000003,
      "end_seconds": 8.44
    },
    {
      "ayah": 3,
      "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "start_seconds": 8.44,
      "end_seconds": 12.92
    },
    {
      "ayah": 4,
      "text": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
      "start_seconds": 12.92,
      "end_seconds": 17.22
    },
    {
      "ayah": 5,
      "text": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
      "start_seconds": 17.22,
      "end_seconds": 24.72
    },
    {
      "ayah": 7,
      "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "start_seconds": 24.72,
      "end_seconds": 28.92
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
      "start_seconds": 28.92,
      "end_seconds": 34.92
    },
    {
      "ayah": 10,
      "text": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
      "start_seconds": 34.92,
      "end_seconds": 39.92
    },
    {
      "ayah": 11,
      "text": "كَلَّآ إِنَّهَا تَذْكِرَةٌ",
      "start_seconds": 39.92,
      "end_seconds": 43.160000000000004
    },
    {
      "ayah": 12,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ",
      "start_seconds": 43.160000000000004,
      "end_seconds": 47.24
    },
    {
      "ayah": 13,
      "text": "فِى صُحُفٍ مُّكَرَّمَةٍ",
      "start_seconds": 47.24,
      "end_seconds": 50.120000000000005
    },
    {
      "ayah": 14,
      "text": "مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ",
      "start_seconds": 50.12,
      "end_seconds": 53.32
    },
    {
      "ayah": 15,
      "text": "بِأَيْدِى سَفَرَةٍ",
      "start_seconds": 53.32000000000001,
      "end_seconds": 55.28
    },
    {
      "ayah": 16,
      "text": "كِرَامٍۭ بَرَرَةٍ",
      "start_seconds": 55.28,
      "end_seconds": 57.36
    },
    {
      "ayah": 17,
      "text": "قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ",
      "start_seconds": 57.44,
      "end_seconds": 63.12
    },
    {
      "ayah": 18,
      "text": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
      "start_seconds": 63.12,
      "end_seconds": 66.12
    },
    {
      "ayah": 19,
      "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
      "start_seconds": 66.12,
      "end_seconds": 70.28
    },
    {
      "ayah": 20,
      "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
      "start_seconds": 70.28,
      "end_seconds": 73.84
    },
    {
      "ayah": 21,
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
      "start_seconds": 73.84,
      "end_seconds": 77.68
    },
    {
      "ayah": 22,
      "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
      "start_seconds": 77.68,
      "end_seconds": 84.24
    },
    {
      "ayah": 23,
      "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
      "start_seconds": 84.28,
      "end_seconds": 88.08
    },
    {
      "ayah": 24,
      "text": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ",
      "start_seconds": 88.08,
      "end_seconds": 93.03999999999999
    },
    {
      "ayah": 25,
      "text": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا",
      "start_seconds": 93.03999999999999,
      "end_seconds": 97.47999999999999
    },
    {
      "ayah": 26,
      "text": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا",
      "start_seconds": 97.47999999999999,
      "end_seconds": 102.84
    },
    {
      "ayah": 27,
      "text": "فَأَنۢبَتْنَا فِيهَا حَبًّا",
      "start_seconds": 102.84,
      "end_seconds": 106.56
    },
    {
      "ayah": 28,
      "text": "وَعِنَبًا وَقَضْبًا",
      "start_seconds": 106.56,
      "end_seconds": 109.28
    },
    {
      "ayah": 29,
      "text": "وَزَيْتُونًا وَنَخْلًا",
      "start_seconds": 109.28,
      "end_seconds": 112.16
    },
    {
      "ayah": 30,
      "text": "وَحَدَآئِقَ غُلْبًا",
      "start_seconds": 112.2,
      "end_seconds": 116.67999999999999
    },
    {
      "ayah": 31,
      "text": "وَفَـٰكِهَةً وَأَبًّا",
      "start_seconds": 116.68,
      "end_seconds": 121.32
    },
    {
      "ayah": 32,
      "text": "مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ",
      "start_seconds": 121.32,
      "end_seconds": 125.56
    },
    {
      "ayah": 33,
      "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
      "start_seconds": 125.56,
      "end_seconds": 132.44
    },
    {
      "ayah": 34,
      "text": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
      "start_seconds": 132.44,
      "end_seconds": 137.08
    },
    {
      "ayah": 35,
      "text": "وَأُمِّهِۦ وَأَبِيهِ",
      "start_seconds": 137.08,
      "end_seconds": 141.0
    },
    {
      "ayah": 36,
      "text": "وَصَـٰحِبَتِهِۦ وَبَنِيهِ",
      "start_seconds": 141.0,
      "end_seconds": 146.04
    },
    {
      "ayah": 37,
      "text": "لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
      "start_seconds": 146.04,
      "end_seconds": 150.68
    },
    {
      "ayah": 38,
      "text": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
      "start_seconds": 154.6,
      "end_seconds": 158.76
    },
    {
      "ayah": 39,
      "text": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
      "start_seconds": 158.76,
      "end_seconds": 161.96
    },
    {
      "ayah": 40,
      "text": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
      "start_seconds": 161.96,
      "end_seconds": 166.92000000000002
    },
    {
      "ayah": 41,
      "text": "تَرْهَقُهَا قَتَرَةٌ",
      "start_seconds": 166.92000000000002,
      "end_seconds": 169.16
    },
    {
      "ayah": 42,
      "text": "أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
      "start_seconds": 169.16,
      "end_seconds": 174.96
    }
  ]
}