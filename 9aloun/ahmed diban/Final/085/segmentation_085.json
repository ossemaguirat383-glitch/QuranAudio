{
  "surah": 85,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ",
      "start_seconds": 0,
      "end_seconds": 9.48
    },
    {
      "ayah": 3,
      "text": "وَشَاهِدٍ وَمَشْهُودٍ",
      "start_seconds": 9.48,
      "end_seconds": 12.88
    },
    {
      "ayah": 4,
      "text": "قُتِلَ أَصْحَـٰبُ ٱلْأُخْدُودِ",
      "start_seconds": 13.120000000000001,
      "end_seconds": 15.96
    },
    {
      "ayah": 5,
      "text": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ",
      "start_seconds": 15.96,
      "end_seconds": 19.400000000000002
    },
    {
      "ayah": 6,
      "text": "إِذْ هُمْ عَلَيْهَا قُعُودٌ",
      "start_seconds": 19.6,
      "end_seconds": 22.92
    },
    {
      "ayah": 7,
      "text": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌ",
      "start_seconds": 23.080000000000002,
      "end_seconds": 28.8
    },
    {
      "ayah": 8,
      "text": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ",
      "start_seconds": 28.96,
      "end_seconds": 37.4
    },
    {
      "ayah": 9,
      "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍ شَهِيدٌ",
      "start_seconds": 37.4,
      "end_seconds": 87.96
    },
    {
      "ayah": 12,
      "text": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ",
      "start_seconds": 87.96,
      "end_seconds": 95.39999999999999
    },
    {
      "ayah": 13,
      "text": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ",
      "start_seconds": 95.39999999999999,
      "end_seconds": 100.56
    },
    {
      "ayah": 14,
      "text": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ",
      "start_seconds": 100.56,
      "end_seconds": 103.76
    },
    {
      "ayah": 15,
      "text": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ",
      "start_seconds": 103.76,
      "end_seconds": 105.76
    },
    {
      "ayah": 16,
      "text": "فَعَّالٌ لِّمَا يُرِيدُ",
      "start_seconds": 105.76,
      "end_seconds": 109.60000000000001
    },
    {
      "ayah": 17,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ",
      "start_seconds": 109.60000000000001,
      "end_seconds": 113.44
    },
    {
      "ayah": 18,
      "text": "فِرْعَوْنَ وَثَمُودَ",
      "start_seconds": 113.44,
      "end_seconds": 117.44
    },
    {
      "ayah": 19,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍ",
      "start_seconds": 117.44,
      "end_seconds": 122.2
    },
    {
      "ayah": 20,
      "text": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ",
      "start_seconds": 122.2,
      "end_seconds": 127.88000000000001
    },
    {
      "ayah": 21,
      "text": "بَلْ هُوَ قُرْءَانٌ مَّجِيدٌ",
      "start_seconds": 127.88000000000001,
      "end_seconds": 133.0
    },
    {
      "ayah": 22,
      "text": "فِى لَوْحٍ مَّحْفُوظٍۭ",
      "start_seconds": 133.0,
      "end_seconds": 140.32
    }
  ]
}