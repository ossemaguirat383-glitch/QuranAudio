{
  "surah": 92,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ",
      "start_seconds": 0,
      "end_seconds": 8.44
    },
    {
      "ayah": 3,
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "start_seconds": 8.44,
      "end_seconds": 13.08
    },
    {
      "ayah": 4,
      "text": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
      "start_seconds": 13.08,
      "end_seconds": 18.44
    },
    {
      "ayah": 5,
      "text": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ",
      "start_seconds": 18.44,
      "end_seconds": 25.16
    },
    {
      "ayah": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ",
      "start_seconds": 25.16,
      "end_seconds": 28.68
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ",
      "start_seconds": 28.8,
      "end_seconds": 36.0
    },
    {
      "ayah": 10,
      "text": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ",
      "start_seconds": 36.0,
      "end_seconds": 39.6
    },
    {
      "ayah": 11,
      "text": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
      "start_seconds": 39.6,
      "end_seconds": 45.28
    },
    {
      "ayah": 12,
      "text": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
      "start_seconds": 45.28,
      "end_seconds": 50.16
    },
    {
      "ayah": 13,
      "text": "وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ",
      "start_seconds": 50.16,
      "end_seconds": 55.04
    },
    {
      "ayah": 14,
      "text": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ",
      "start_seconds": 55.08,
      "end_seconds": 60.72
    },
    {
      "ayah": 15,
      "text": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى",
      "start_seconds": 60.72,
      "end_seconds": 67.84
    },
    {
      "ayah": 17,
      "text": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى",
      "start_seconds": 67.84,
      "end_seconds": 71.4
    },
    {
      "ayah": 18,
      "text": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ",
      "start_seconds": 71.4,
      "end_seconds": 76.28
    },
    {
      "ayah": 19,
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ",
      "start_seconds": 76.28,
      "end_seconds": 83.03999999999999
    },
    {
      "ayah": 20,
      "text": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ",
      "start_seconds": 83.04,
      "end_seconds": 89.24000000000001
    },
    {
      "ayah": 21,
      "text": "وَلَسَوْفَ يَرْضَىٰ",
      "start_seconds": 89.24000000000001,
      "end_seconds": 92.28
    }
  ]
}