{
  "surah": 93,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
      "start_seconds": 0.0,
      "end_seconds": 3.24
    },
    {
      "ayah": 2,
      "text": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "start_seconds": 3.24,
      "end_seconds": 7.6
    },
    {
      "ayah": 3,
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "start_seconds": 7.6000000000000005,
      "end_seconds": 11.56
    },
    {
      "ayah": 4,
      "text": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ",
      "start_seconds": 11.56,
      "end_seconds": 16.36
    },
    {
      "ayah": 5,
      "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "start_seconds": 16.36,
      "end_seconds": 20.6
    },
    {
      "ayah": 6,
      "text": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ",
      "start_seconds": 20.6,
      "end_seconds": 25.8
    },
    {
      "ayah": 7,
      "text": "وَوَجَدَكَ ضَآلًّا فَهَدَىٰ",
      "start_seconds": 25.92,
      "end_seconds": 32.96
    },
    {
      "ayah": 8,
      "text": "وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ",
      "start_seconds": 32.96,
      "end_seconds": 39.16
    },
    {
      "ayah": 9,
      "text": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
      "start_seconds": 39.16,
      "end_seconds": 43.48
    },
    {
      "ayah": 10,
      "text": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
      "start_seconds": 43.480000000000004,
      "end_seconds": 48.519999999999996
    },
    {
      "ayah": 11,
      "text": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "start_seconds": 48.519999999999996,
      "end_seconds": 54.08
    }
  ]
}