{
  "surah": 84,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ",
      "start_seconds": 0,
      "end_seconds": 29.24
    },
    {
      "ayah": 7,
      "text": "فَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ بِيَمِينِهِۦ",
      "start_seconds": 29.24,
      "end_seconds": 39.36
    },
    {
      "ayah": 9,
      "text": "وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًا",
      "start_seconds": 39.36,
      "end_seconds": 44.16
    },
    {
      "ayah": 10,
      "text": "وَأَمَّا مَنْ أُوتِىَ كِتَـٰبَهُۥ وَرَآءَ ظَهْرِهِۦ",
      "start_seconds": 44.16,
      "end_seconds": 54.12
    },
    {
      "ayah": 11,
      "text": "فَسَوْفَ يَدْعُوا۟ ثُبُورًا",
      "start_seconds": 54.12,
      "end_seconds": 67.2
    },
    {
      "ayah": 15,
      "text": "بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًا",
      "start_seconds": 67.2,
      "end_seconds": 74.52
    },
    {
      "ayah": 16,
      "text": "فَلَآ أُقْسِمُ بِٱلشَّفَقِ",
      "start_seconds": 74.52,
      "end_seconds": 79.6
    },
    {
      "ayah": 17,
      "text": "وَٱلَّيْلِ وَمَا وَسَقَ",
      "start_seconds": 79.6,
      "end_seconds": 91.11999999999999
    },
    {
      "ayah": 21,
      "text": "وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩",
      "start_seconds": 91.11999999999999,
      "end_seconds": 101.19999999999999
    },
    {
      "ayah": 22,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ",
      "start_seconds": 101.19999999999999,
      "end_seconds": 101.2
    },
    {
      "ayah": 23,
      "text": "وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ",
      "start_seconds": 101.2,
      "end_seconds": 106.48
    },
    {
      "ayah": 24,
      "text": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ",
      "start_seconds": 106.48,
      "end_seconds": 110.64
    },
    {
      "ayah": 25,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ",
      "start_seconds": 110.64,
      "end_seconds": 120.84
    }
  ]
}