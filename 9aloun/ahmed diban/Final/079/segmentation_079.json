{
  "surah": 79,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلنَّـٰزِعَـٰتِ غَرْقًا",
      "start_seconds": 0,
      "end_seconds": 17.16
    },
    {
      "ayah": 6,
      "text": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ",
      "start_seconds": 17.16,
      "end_seconds": 22.04
    },
    {
      "ayah": 8,
      "text": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ",
      "start_seconds": 22.04,
      "end_seconds": 28.6
    },
    {
      "ayah": 10,
      "text": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
      "start_seconds": 28.6,
      "end_seconds": 34.2
    },
    {
      "ayah": 11,
      "text": "أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً",
      "start_seconds": 34.2,
      "end_seconds": 38.72
    },
    {
      "ayah": 12,
      "text": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
      "start_seconds": 38.72,
      "end_seconds": 43.120000000000005
    },
    {
      "ayah": 13,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ",
      "start_seconds": 43.120000000000005,
      "end_seconds": 47.52
    },
    {
      "ayah": 14,
      "text": "فَإِذَا هُم بِٱلسَّاهِرَةِ",
      "start_seconds": 47.52,
      "end_seconds": 50.28
    },
    {
      "ayah": 15,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ",
      "start_seconds": 50.28,
      "end_seconds": 53.6
    },
    {
      "ayah": 16,
      "text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
      "start_seconds": 53.6,
      "end_seconds": 59.6
    },
    {
      "ayah": 17,
      "text": "ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ",
      "start_seconds": 59.6,
      "end_seconds": 64.24
    },
    {
      "ayah": 18,
      "text": "فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ",
      "start_seconds": 64.24000000000001,
      "end_seconds": 68.72
    },
    {
      "ayah": 19,
      "text": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ",
      "start_seconds": 68.72,
      "end_seconds": 72.84
    },
    {
      "ayah": 20,
      "text": "فَأَرَىٰهُ ٱلْـَٔايَةَ ٱلْكُبْرَىٰ",
      "start_seconds": 72.84,
      "end_seconds": 76.04
    },
    {
      "ayah": 21,
      "text": "فَكَذَّبَ وَعَصَىٰ",
      "start_seconds": 76.04,
      "end_seconds": 78.28
    },
    {
      "ayah": 22,
      "text": "ثُمَّ أَدْبَرَ يَسْعَىٰ",
      "start_seconds": 78.28,
      "end_seconds": 81.32
    },
    {
      "ayah": 23,
      "text": "فَحَشَرَ فَنَادَىٰ",
      "start_seconds": 81.36,
      "end_seconds": 83.6
    },
    {
      "ayah": 24,
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ",
      "start_seconds": 83.6,
      "end_seconds": 87.24
    },
    {
      "ayah": 25,
      "text": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْـَٔاخِرَةِ وَٱلْأُولَىٰٓ",
      "start_seconds": 87.24,
      "end_seconds": 92.76
    },
    {
      "ayah": 26,
      "text": "إِنَّ فِى ذَٰلِكَ لَعِبْرَةً لِّمَن يَخْشَىٰٓ",
      "start_seconds": 92.75999999999999,
      "end_seconds": 99.67999999999999
    },
    {
      "ayah": 27,
      "text": "ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا",
      "start_seconds": 99.68,
      "end_seconds": 105.76
    },
    {
      "ayah": 28,
      "text": "رَفَعَ سَمْكَهَا فَسَوَّىٰهَا",
      "start_seconds": 105.75999999999999,
      "end_seconds": 110.67999999999999
    },
    {
      "ayah": 29,
      "text": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا",
      "start_seconds": 110.72000000000001,
      "end_seconds": 115.32000000000001
    },
    {
      "ayah": 30,
      "text": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ",
      "start_seconds": 115.32000000000001,
      "end_seconds": 119.48
    },
    {
      "ayah": 31,
      "text": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا",
      "start_seconds": 119.48,
      "end_seconds": 124.96000000000001
    },
    {
      "ayah": 32,
      "text": "وَٱلْجِبَالَ أَرْسَىٰهَا",
      "start_seconds": 124.96000000000001,
      "end_seconds": 132.44
    },
    {
      "ayah": 34,
      "text": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ",
      "start_seconds": 132.44,
      "end_seconds": 140.28
    },
    {
      "ayah": 35,
      "text": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَـٰنُ مَا سَعَىٰ",
      "start_seconds": 140.32,
      "end_seconds": 145.28
    },
    {
      "ayah": 36,
      "text": "وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ",
      "start_seconds": 145.28,
      "end_seconds": 150.6
    },
    {
      "ayah": 37,
      "text": "فَأَمَّا مَن طَغَىٰ",
      "start_seconds": 150.6,
      "end_seconds": 157.56
    },
    {
      "ayah": 39,
      "text": "فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ",
      "start_seconds": 157.56,
      "end_seconds": 162.76
    },
    {
      "ayah": 40,
      "text": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ",
      "start_seconds": 162.76,
      "end_seconds": 169.48
    },
    {
      "ayah": 41,
      "text": "فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ",
      "start_seconds": 172.56,
      "end_seconds": 177.68
    },
    {
      "ayah": 42,
      "text": "يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا",
      "start_seconds": 177.67999999999998,
      "end_seconds": 183.12
    },
    {
      "ayah": 43,
      "text": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ",
      "start_seconds": 183.12,
      "end_seconds": 188.44
    },
    {
      "ayah": 44,
      "text": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ",
      "start_seconds": 188.44,
      "end_seconds": 192.48
    },
    {
      "ayah": 45,
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا",
      "start_seconds": 192.48,
      "end_seconds": 199.07999999999998
    }
  ]
}