{
  "surah": 101,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ",
      "start_seconds": 0.0,
      "end_seconds": 3.88
    },
    {
      "ayah": 2,
      "text": "مَا ٱلْقَارِعَةُ",
      "start_seconds": 3.88,
      "end_seconds": 10.32
    },
    {
      "ayah": 4,
      "text": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
      "start_seconds": 10.32,
      "end_seconds": 16.28
    },
    {
      "ayah": 5,
      "text": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
      "start_seconds": 16.28,
      "end_seconds": 22.88
    },
    {
      "ayah": 6,
      "text": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
      "start_seconds": 22.88,
      "end_seconds": 28.400000000000002
    },
    {
      "ayah": 7,
      "text": "فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ",
      "start_seconds": 28.479999999999997,
      "end_seconds": 31.799999999999997
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
      "start_seconds": 31.799999999999997,
      "end_seconds": 36.48
    },
    {
      "ayah": 9,
      "text": "فَأُمُّهُۥ هَاوِيَةٌ",
      "start_seconds": 36.48,
      "end_seconds": 39.96
    },
    {
      "ayah": 10,
      "text": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
      "start_seconds": 39.96,
      "end_seconds": 45.64
    }
  ]
}