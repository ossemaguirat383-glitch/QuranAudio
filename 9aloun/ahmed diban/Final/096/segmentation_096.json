{
  "surah": 96,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
      "start_seconds": 0,
      "end_seconds": 7.0
    },
    {
      "ayah": 2,
      "text": "خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ",
      "start_seconds": 7.0,
      "end_seconds": 10.4
    },
    {
      "ayah": 3,
      "text": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
      "start_seconds": 10.4,
      "end_seconds": 13.3
    },
    {
      "ayah": 4,
      "text": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
      "start_seconds": 13.3,
      "end_seconds": 16.3
    },
    {
      "ayah": 5,
      "text": "عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ",
      "start_seconds": 16.3,
      "end_seconds": 20.3
    },
    {
      "ayah": 6,
      "text": "كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ",
      "start_seconds": 20.3,
      "end_seconds": 25.0
    },
    {
      "ayah": 7,
      "text": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
      "start_seconds": 25.0,
      "end_seconds": 27.6
    },
    {
      "ayah": 8,
      "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
      "start_seconds": 27.6,
      "end_seconds": 31.6
    },
    {
      "ayah": 9,
      "text": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
      "start_seconds": 31.6,
      "end_seconds": 34.4
    },
    {
      "ayah": 10,
      "text": "عَبْدًا إِذَا صَلَّىٰٓ",
      "start_seconds": 34.4,
      "end_seconds": 37.0
    },
    {
      "ayah": 11,
      "text": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
      "start_seconds": 37.0,
      "end_seconds": 40.6
    },
    {
      "ayah": 12,
      "text": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
      "start_seconds": 40.6,
      "end_seconds": 43.1
    },
    {
      "ayah": 13,
      "text": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "start_seconds": 43.1,
      "end_seconds": 47.6
    },
    {
      "ayah": 14,
      "text": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "start_seconds": 47.6,
      "end_seconds": 53.3
    },
    {
      "ayah": 15,
      "text": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
      "start_seconds": 53.3,
      "end_seconds": 59.4
    },
    {
      "ayah": 16,
      "text": "نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ",
      "start_seconds": 59.4,
      "end_seconds": 64.4
    },
    {
      "ayah": 17,
      "text": "فَلْيَدْعُ نَادِيَهُۥ",
      "start_seconds": 64.4,
      "end_seconds": 66.6
    },
    {
      "ayah": 18,
      "text": "سَنَدْعُ ٱلزَّبَانِيَةَ",
      "start_seconds": 66.6,
      "end_seconds": 69.1
    }
  ]
}