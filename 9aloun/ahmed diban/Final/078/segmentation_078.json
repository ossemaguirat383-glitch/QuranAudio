{
  "surah": 78,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ عَمَّ يَتَسَآءَلُونَ",
      "start_seconds": 0.0,
      "end_seconds": 3.16
    },
    {
      "ayah": 2,
      "text": "عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ",
      "start_seconds": 3.16,
      "end_seconds": 13.72
    },
    {
      "ayah": 4,
      "text": "كَلَّا سَيَعْلَمُونَ",
      "start_seconds": 13.72,
      "end_seconds": 18.72
    },
    {
      "ayah": 5,
      "text": "ثُمَّ كَلَّا سَيَعْلَمُونَ",
      "start_seconds": 18.72,
      "end_seconds": 18.88
    },
    {
      "ayah": 6,
      "text": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَـٰدًا",
      "start_seconds": 18.88,
      "end_seconds": 24.52
    },
    {
      "ayah": 7,
      "text": "وَٱلْجِبَالَ أَوْتَادًا",
      "start_seconds": 24.52,
      "end_seconds": 24.68
    },
    {
      "ayah": 9,
      "text": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا",
      "start_seconds": 24.68,
      "end_seconds": 31.4
    },
    {
      "ayah": 10,
      "text": "وَجَعَلْنَا ٱلَّيْلَ لِبَاسًا",
      "start_seconds": 31.4,
      "end_seconds": 38.519999999999996
    },
    {
      "ayah": 12,
      "text": "وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا",
      "start_seconds": 38.519999999999996,
      "end_seconds": 44.0
    },
    {
      "ayah": 13,
      "text": "وَجَعَلْنَا سِرَاجًا وَهَّاجًا",
      "start_seconds": 44.12,
      "end_seconds": 49.08
    },
    {
      "ayah": 14,
      "text": "وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءً ثَجَّاجًا",
      "start_seconds": 49.24,
      "end_seconds": 55.36
    },
    {
      "ayah": 15,
      "text": "لِّنُخْرِجَ بِهِۦ حَبًّا وَنَبَاتًا",
      "start_seconds": 55.519999999999996,
      "end_seconds": 63.24
    },
    {
      "ayah": 16,
      "text": "وَجَنَّـٰتٍ أَلْفَافًا",
      "start_seconds": 63.24,
      "end_seconds": 63.400000000000006
    },
    {
      "ayah": 17,
      "text": "إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَـٰتًا",
      "start_seconds": 63.400000000000006,
      "end_seconds": 67.64
    },
    {
      "ayah": 18,
      "text": "يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًا",
      "start_seconds": 67.8,
      "end_seconds": 73.2
    },
    {
      "ayah": 19,
      "text": "وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًا",
      "start_seconds": 73.36,
      "end_seconds": 78.8
    },
    {
      "ayah": 20,
      "text": "وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا",
      "start_seconds": 78.96,
      "end_seconds": 83.4
    },
    {
      "ayah": 21,
      "text": "إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا",
      "start_seconds": 83.56,
      "end_seconds": 88.96000000000001
    },
    {
      "ayah": 22,
      "text": "لِّلطَّـٰغِينَ مَـَٔابًا",
      "start_seconds": 88.96000000000001,
      "end_seconds": 95.16
    },
    {
      "ayah": 24,
      "text": "لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا",
      "start_seconds": 95.16,
      "end_seconds": 100.48
    },
    {
      "ayah": 25,
      "text": "إِلَّا حَمِيمًا وَغَسَّاقًا",
      "start_seconds": 100.64,
      "end_seconds": 109.0
    },
    {
      "ayah": 26,
      "text": "جَزَآءً وِفَاقًا",
      "start_seconds": 109.0,
      "end_seconds": 109.16
    },
    {
      "ayah": 27,
      "text": "إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًا",
      "start_seconds": 109.16,
      "end_seconds": 114.44
    },
    {
      "ayah": 28,
      "text": "وَكَذَّبُوا۟ بِـَٔايَـٰتِنَا كِذَّابًا",
      "start_seconds": 114.60000000000001,
      "end_seconds": 118.76
    },
    {
      "ayah": 29,
      "text": "وَكُلَّ شَىْءٍ أَحْصَيْنَـٰهُ كِتَـٰبًا",
      "start_seconds": 118.92,
      "end_seconds": 123.92
    },
    {
      "ayah": 30,
      "text": "فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا",
      "start_seconds": 124.12,
      "end_seconds": 130.92000000000002
    },
    {
      "ayah": 31,
      "text": "إِنَّ لِلْمُتَّقِينَ مَفَازًا",
      "start_seconds": 131.08,
      "end_seconds": 135.4
    },
    {
      "ayah": 32,
      "text": "حَدَآئِقَ وَأَعْنَـٰبًا",
      "start_seconds": 135.56,
      "end_seconds": 140.56
    },
    {
      "ayah": 33,
      "text": "وَكَوَاعِبَ أَتْرَابًا",
      "start_seconds": 140.72,
      "end_seconds": 147.16
    },
    {
      "ayah": 34,
      "text": "وَكَأْسًا دِهَاقًا",
      "start_seconds": 147.16,
      "end_seconds": 147.32
    },
    {
      "ayah": 35,
      "text": "لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّٰبًا",
      "start_seconds": 147.32,
      "end_seconds": 152.96
    },
    {
      "ayah": 36,
      "text": "جَزَآءً مِّن رَّبِّكَ عَطَآءً حِسَابًا",
      "start_seconds": 153.12,
      "end_seconds": 160.24
    },
    {
      "ayah": 37,
      "text": "رَّبِّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَـٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا",
      "start_seconds": 160.4,
      "end_seconds": 167.24
    },
    {
      "ayah": 38,
      "text": "يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَـٰٓئِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَـٰنُ وَقَالَ صَوَابًا",
      "start_seconds": 167.24,
      "end_seconds": 191.16
    },
    {
      "ayah": 39,
      "text": "ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا",
      "start_seconds": 191.16,
      "end_seconds": 198.36
    }
  ]
}