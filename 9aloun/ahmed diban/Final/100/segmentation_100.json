{
  "surah": 100,
  "ayahs": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ وَٱلْعَـٰدِيَـٰتِ ضَبْحًا",
      "start_seconds": 0,
      "end_seconds": 7.0
    },
    {
      "ayah": 2,
      "text": "فَٱلْمُورِيَـٰتِ قَدْحًا",
      "start_seconds": 7.0,
      "end_seconds": 9.8
    },
    {
      "ayah": 3,
      "text": "فَٱلْمُغِيرَٰتِ صُبْحًا",
      "start_seconds": 9.8,
      "end_seconds": 12.68
    },
    {
      "ayah": 4,
      "text": "فَأَثَرْنَ بِهِۦ نَقْعًا",
      "start_seconds": 12.68,
      "end_seconds": 15.96
    },
    {
      "ayah": 5,
      "text": "فَوَسَطْنَ بِهِۦ جَمْعًا",
      "start_seconds": 15.96,
      "end_seconds": 19.04
    },
    {
      "ayah": 6,
      "text": "إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ",
      "start_seconds": 19.04,
      "end_seconds": 27.240000000000002
    },
    {
      "ayah": 7,
      "text": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ",
      "start_seconds": 27.36,
      "end_seconds": 32.199999999999996
    },
    {
      "ayah": 8,
      "text": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ",
      "start_seconds": 32.199999999999996,
      "end_seconds": 37.36
    },
    {
      "ayah": 9,
      "text": "أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ",
      "start_seconds": 37.36,
      "end_seconds": 43.879999999999995
    },
    {
      "ayah": 10,
      "text": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ",
      "start_seconds": 43.88,
      "end_seconds": 47.52
    },
    {
      "ayah": 11,
      "text": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ",
      "start_seconds": 47.519999999999996,
      "end_seconds": 55.44
    }
  ]
}