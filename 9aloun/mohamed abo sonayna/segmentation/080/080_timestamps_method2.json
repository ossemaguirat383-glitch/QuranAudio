    "start_seconds": 24.560000000000002,
    "end_seconds": 35.040000000000006,
    "start_time": "00:24",
    "end_time": "00:35",
    "segment_text": " أما من استغنى فأنت له تصدى وما عليك ألا يزكى",
    "matched_ayah_text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
