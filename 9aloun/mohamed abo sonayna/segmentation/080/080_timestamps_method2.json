    "start_seconds": 48.160000000000004,
    "end_seconds": 56.800000000000004,
    "start_time": "00:48",
    "end_time": "00:56",
    "segment_text": " إنها تذكرة فمن شاء ذكره",
    "matched_ayah_text": "فَمَن شَآءَ ذَكَرَهُۥ",
