    "start_seconds": 35.92,
    "end_seconds": 47.84,
    "start_time": "00:35",
    "end_time": "00:47",
    "segment_text": " وأما من جاءك يسعى وهو يخشى فأنت عنه تلهى كلا",
    "matched_ayah_text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
