      "matched_text": "إذا كنا عظاما نخرى",
      "confidence": 1,
      "matched_word_indices": [
        32,
        35
      ]
    },
    {
      "ayah": 12,
      "text": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
