      "confidence": 1,
      "matched_word_indices": [
        6,
        11
      ]
    },
    {
      "ayah": 3,
      "text": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ",
      "start": 14.08,
      "end": 19.58,
      "matched_text": "وإذا كالوهم وأوزنوهم يخسرون",
      "confidence": 0.8,
      "matched_word_indices": [
        12,
        15
      ]
    },
    {
      "ayah": 4,
      "text": "أَلَا يَظُنُّ أُو۟لَـٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ",
      "start": 20.56,
      "end": 27.86,
      "matched_text": "ألا يظن أولئك أنهم مبعوثون",
      "confidence": 1,
      "matched_word_indices": [
        17,
        21
      ]
    },
    {
      "ayah": 5,
      "text": "لِيَوْمٍ عَظِيمٍ",
