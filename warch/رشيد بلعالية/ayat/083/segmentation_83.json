      "matched_word_indices": [
        44,
        47
      ]
    },
    {
      "ayah": 11,
      "text": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ",
      "start": 55.7,
      "end": 60.36,
