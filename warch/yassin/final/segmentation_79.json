      "confidence": 1,
      "matched_word_indices": [
        28,
        33
      ]
    },
    {
      "ayah": 11,
      "text": "أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً",
      "start": 37.06,
      "end": 41.64,
      "matched_text": "إذا كنا عظاما نخرة",
      "confidence": 1,
      "matched_word_indices": [
        34,
        37
      ]
    },
    {
      "ayah": 12,
      "text": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
