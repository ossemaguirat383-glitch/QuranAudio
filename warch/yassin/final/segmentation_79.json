      "matched_text": "فإنما هي زجرة واحدة",
      "confidence": 1,
      "matched_word_indices": [
        44,
        47
      ]
    },
    {
      "ayah": 14,
      "text": "فَإِذَا هُم بِٱلسَّاهِرَةِ",
