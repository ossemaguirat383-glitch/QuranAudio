      "matched_text": "هل تاك حديث موسى",
      "confidence": 1,
      "matched_word_indices": [
        52,
        55
      ]
    },
    {
      "ayah": 16,
      "text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
      "start": 62.27,
