    "end_seconds": 42.480000000000004,
    "start_time": "00:31",
    "end_time": "00:42",
    "segment_text": " يقولون أإنا لمردودون في الحافرة إذا كنا عظاماً نخرة",
    "matched_ayah_text": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
