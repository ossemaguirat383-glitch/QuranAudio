    "end_seconds": 67.92,
    "start_time": "00:56",
    "end_time": "01:07",
    "segment_text": " هل تاك حديث موسى إذ ناداه ربه بالواد المقدس طوا",
    "matched_ayah_text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
