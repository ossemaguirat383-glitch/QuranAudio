    "end_seconds": 56.239999999999995,
    "start_time": "00:42",
    "end_time": "00:56",
    "segment_text": " قالوا تلك إذا كرة خاسرة فإنما هي زجرة واحدة فإذا هم بالساهرة",
    "matched_ayah_text": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
