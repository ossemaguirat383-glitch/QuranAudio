    "end_seconds": 12.88,
    "start_time": "00:04",
    "end_time": "00:12",
    "segment_text": " ويل للمطففين الذين إذا كتالوا على الناس يستوفون",
    "matched_ayah_text": "ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ",
