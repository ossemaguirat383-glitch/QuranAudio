    "end_seconds": 21.36,
    "start_time": "00:12",
    "end_time": "00:21",
    "segment_text": " وإذا كالوا هم أوزنوهم يخسرون",
    "matched_ayah_text": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ",
